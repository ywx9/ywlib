/// @brief Direct2D device
inline comptr<ID2D1Device> d2d_device = [] {
  if (!(dxgi_device && d2d_factory)) return comptr<ID2D1Device>{};
  try {
    comptr<ID2D1Device> temp;
    tiff(d2d_factory->CreateDevice(dxgi_device, temp.init()));
    return std::move(temp);
  } catch(...) { return comptr<ID2D1Device>{}; } }();

/// @brief Direct2D device context
inline comptr<ID2D1DeviceContext> d2d_context = [] {
  if (!(d2d_device)) return comptr<ID2D1DeviceContext>{};
  try {
    comptr<ID2D1DeviceContext> temp;
    tiff(d2d_device->CreateDeviceContext(D2D1_DEVICE_CONTEXT_OPTIONS_NONE, temp.init()));
    return std::move(temp);
  } catch(...) { return comptr<ID2D1DeviceContext>{}; } }();

/// @brief Direct2D bitmap for rendering
inline comptr<ID2D1Bitmap1> rendertarget = [] {
  if (!(d2d_context && swapchain)) return comptr<ID2D1Bitmap1>{};
  try {
    comptr<ID3D11Texture2D> tex;
    tiff(swapchain->GetBuffer(0, IID_PPV_ARGS(tex.init())));
    comptr<IDXGISurface> surface;
    tiff(tex->QueryInterface(IID_PPV_ARGS(surface.init())));
    auto p = D2D1::BitmapProperties1(D2D1_BITMAP_OPTIONS_TARGET | D2D1_BITMAP_OPTIONS_CANNOT_DRAW,
                                     D2D1::PixelFormat(DXGI_FORMAT_UNKNOWN, D2D1_ALPHA_MODE_PREMULTIPLIED));
    comptr<ID2D1Bitmap1> temp;
    tiff(d2d_context->CreateBitmapFromDxgiSurface(surface, &p, temp.init()));
    return std::move(temp);
  } catch(...) { return comptr<ID2D1Bitmap1>{}; } }();

/// @brief DirectWrite factory
inline comptr<IDWriteFactory> dw_factory = [] {
  if (!com_initialized) return comptr<IDWriteFactory>{};
  try {
    comptr<IDWriteFactory> temp;
    tiff(::DWriteCreateFactory(DWRITE_FACTORY_TYPE_SHARED, __uuidof(IDWriteFactory), (IUnknown**)temp.init()));
    return std::move(temp);
  } catch(...) { return comptr<IDWriteFactory>{}; } }();

/// @brief Windows Imaging Component factory
inline comptr<IWICImagingFactory> wic_factory = [] {
  if (!com_initialized) return comptr<IWICImagingFactory>{};
  try {
    comptr<IWICImagingFactory> temp;
    tiff(::CoCreateInstance(CLSID_WICImagingFactory2, nullptr, CLSCTX_INPROC_SERVER, IID_PPV_ARGS(temp.init())));
    return std::move(temp);
  } catch(...) { return comptr<IWICImagingFactory>{}; } }();

