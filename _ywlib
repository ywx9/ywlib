/// @brief Structure for representing a source location.
struct source {
  const char* file;
  const int line, column;
  source(const char* const) = delete;
  constexpr source(const char* const File = __builtin_FILE(), const int Line = __builtin_LINE(),
                   const int Column = __builtin_COLUMN()) : file(File), line(Line), column(Column) {}
  std::string to_text() const { return std::format("{}({},{})", file, line, column); }
  template<typename Tr> friend std::basic_ostream<char, Tr>&
  operator<<(std::basic_ostream<char, Tr>& os, const source& s) { return os << s.to_text(); }
};

// STOPWATCH ///////////////////////////////////////////////////////////////////

/// @brief structure for measuring time
class stopwatch {
  inline static double freq = [](LARGE_INTEGER _) { return ::QueryPerformanceFrequency(&_), double(_.QuadPart); }({});
  mutable LARGE_INTEGER li;
  long long last;
public:
  stopwatch() noexcept : li{}, last{(::QueryPerformanceCounter(&li), li.QuadPart)} {}
  double operator()() const noexcept { return *this; }
  operator double() const noexcept { return ::QueryPerformanceCounter(&li), (li.QuadPart - last) / freq; }
  operator float() const noexcept { return float(operator double()); }
  void reset() noexcept { ::QueryPerformanceCounter(&li), last = li.QuadPart; }
  double split() noexcept { return ::QueryPerformanceCounter(&li), (li.QuadPart - exchange(last, li.QuadPart)) / freq; }
};

// TIFF ////////////////////////////////////////////////////////////////////////

/// @brief throws an exception if `Result` is `false`
inline void tiff(const auto& Result, const std::string_view Message, const source& _ = {})
  requires requires { { !Result } -> std::convertible_to<bool>; } {
  if (!Result) {
    auto text = std::format("{}\n at {}({},{})", Message, _.file, _.line, _.column);
    throw std::exception(text.data());
  }
}

/// @brief throws an exception if `Result` is `FAILED`
inline void tiff(const HRESULT Result, const source& _ = {}) {
  if (SUCCEEDED(Result)) return;
  char* buffer = memo<char, 128>;
  ::FormatMessageA(FORMAT_MESSAGE_FROM_SYSTEM | FORMAT_MESSAGE_IGNORE_INSERTS, nullptr,
                   Result, MAKELANGID(LANG_NEUTRAL, SUBLANG_DEFAULT), buffer, 128, nullptr);
  auto text = std::format("{}\n at {}({},{})", buffer, _.file, _.line, _.column);
  throw std::exception(text.data());
}

/// @brief wrapper class for `std::exception`
struct except {
  const std::exception& wrapped;
  void receive(const source& _ = {}) const {
    auto text = std::format("{}\n at {}({},{})", wrapped.what(), _.file, _.line, _.column);
    std::cout << text << std::endl;
    ::MessageBoxA(nullptr, text.data(), "Exception", MB_ICONERROR | MB_OK);
  }
  void reray(const source& _ = {}) const {
    auto text = std::format("{}\n at {}({},{})", wrapped.what(), _.file, _.line, _.column);
    throw std::exception(text.data());
  }
};

