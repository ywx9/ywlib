/// @brief terminates the system
inline void terminate() {
  system::wic_factory.reset();
  system::dw_factory.reset();
  system::rendertarget.reset();
  system::d2d_context.reset();
  system::d2d_device.reset();
  system::d2d_factory.reset();
  system::swapchain.reset();
  system::dxgi_device.reset();
  system::dxgi_factory.reset();
  system::d3d_context.reset();
  system::d3d_device.reset();
  if (system::com_initialized) ::CoUninitialize();
  if (system::hwnd) ::DestroyWindow(exchange(const_cast<HWND&>(system::hwnd), nullptr));
}

/// @brief sets the main window title
inline void rename(const std::wstring_view& Name) { SetWindowTextW(system::hwnd, Name.data()); }

/// @brief resizes the main window
inline void resize(const auto Width, const auto Height, const source _ = {}) {
  using namespace system;
  try {
    rendertarget.reset(), width = int(Width), height = int(Height);
    tiff(::SetWindowPos(hwnd, 0, 0, 0, width + padding_width, height + padding_height, SWP_NOMOVE | SWP_NOZORDER));
    tiff(swapchain->ResizeBuffers(2, UINT(width), UINT(height), DXGI_FORMAT_UNKNOWN, 0));
    comptr<ID3D11Texture2D> tex;
    tiff(swapchain->GetBuffer(0, IID_PPV_ARGS(tex.init())));
    comptr<IDXGISurface> surface;
    tiff(tex->QueryInterface(IID_PPV_ARGS(surface.init())));
    auto props = D2D1::BitmapProperties1(D2D1_BITMAP_OPTIONS_TARGET | D2D1_BITMAP_OPTIONS_CANNOT_DRAW,
                                         D2D1::PixelFormat(DXGI_FORMAT_UNKNOWN, D2D1_ALPHA_MODE_PREMULTIPLIED));
    tiff(d2d_context->CreateBitmapFromDxgiSurface(surface, props, rendertarget.init()));
  } catch (const std::exception& E) { throw std::exception(E, std::move(_)); }
}

using test = decltype(system::keyboard_state[2] + 1);

/// @brief updates the main window
inline constexpr caster update{[]() {
  static stopwatch sw{};
  system::mouse_wheel_delta = 0;
  system::dropped_files.clear();
  system::swapchain->Present(1, 0);
  while (system::hwnd) {
    if (::PeekMessageW(&system::message, nullptr, 0, 0, PM_REMOVE)) {
      ::TranslateMessage(&system::message), ::DispatchMessageW(&system::message);
      if (system::message.message == WM_QUIT) return false;
    } else {
      ::GetKeyboardState(system::keyboard_state[system::keyboard_new ^= 1]);
      // std::cout << int(system::keyboard_state[system::keyboard_new]['A']) << std::endl;
      for (int i{}; i < 256; i += 32) {
        auto new_ = _mm256_loadu_si256((const __m256i*)(system::keyboard_state[system::keyboard_new] + i));
        auto old_ = _mm256_loadu_si256((const __m256i*)(system::keyboard_state[system::keyboard_new ^ 1] + i));
        old_ = _mm256_srli_epi64(_mm256_xor_si256(new_, old_), 4);
        _mm256_storeu_si256((__m256i*)(system::keyboard_state[2] + i), _mm256_or_si256(new_, old_));
      }
      auto mp_old = _mm_loadu_si128((const __m128i*)&system::mpoint);
      ::GetCursorPos((LPPOINT)&system::mpoint);
      ::ScreenToClient(system::hwnd, (LPPOINT)&system::mpoint);
      auto mp = _mm_loadu_si128((const __m128i*)&system::mpoint);
      mp_old = _mm_sub_epi32(mp, mp_old);
      _mm_storeu_ps((float*)&system::mpoint, _mm_shuffle_ps(_mm_castsi128_ps(mp), _mm_castsi128_ps(mp_old), 0b01000100));
      system::spf = sw.split(), system::fps = 1.0f / system::spf;
      return true;
    }
  } return false; }};
}

