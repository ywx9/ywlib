/// @brief COM pointer
template<typename Com> class comptr : public std::unique_ptr<Com, com_deleter<Com>> {
public:
  using base = std::unique_ptr<Com, com_deleter<Com>>;
  using base::unique_ptr;
  using base::operator->;
  using base::operator bool;
  /// @brief implicitly convertion to `Com*`
  operator Com*() const noexcept { return base::get(); }
  /// @brief returns the address of the pointer for initializing Com objects
  Com** init(const source& _ = {}) & {
    if (bool(*this)) throw std::logic_error(std::format("logic error: the pointer is already initialized\n at {}({},{})", _.file, _.line, _.column));
    return reinterpret_cast<Com**>(this);
  }
  /// @brief reinterpret the pointer to another COM
  template<typename U> HRESULT as(comptr<U>& u) const noexcept {
    return operator->()->QueryInterface(__uuidof(U), reinterpret_cast<void**>(this));
  }
};

