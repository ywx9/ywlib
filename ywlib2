template<included_in<int, long, long long, unsigned, unsigned long, unsigned long long, float, double, long double> T> struct t_stov {
  T operator()(const std::string& Str) const noexcept { return call(Str); }
  T operator()(const std::wstring& Str) const noexcept { return call(Str); }
private:
  static auto call(auto Str) noexcept {
    for (; Str.size(); Str.erase(0, 1)) {
      try {
        if constexpr (same_as<remove_cv<T>, double>) return std::stod(Str);
        else if constexpr (same_as<remove_cv<T>, float>) return std::stof(Str);
        else if constexpr (same_as<remove_cv<T>, long double>) return std::stold(Str);
        else if constexpr (same_as<remove_cv<T>, long long>) return std::stoll(Str);
        else if constexpr (same_as<remove_cv<T>, int>) return std::stoi(Str);
        else if constexpr (same_as<remove_cv<T>, long>) return std::stol(Str);
        else if constexpr (same_as<remove_cv<T>, unsigned long long>) return std::stoull(Str);
        else if constexpr (same_as<remove_cv<T>, unsigned>) return unsigned(std::stoul(Str));
        else if constexpr (same_as<remove_cv<T>, unsigned long>) return std::stoul(Str);
        else return T(std::stoud(Str));
      } catch (const std::exception&) { continue; }
    }
    return T{};
  }
};
template<arithmetic T> inline constexpr t_stov<T> stov;

template<included_in<char, wchar_t> Ct> inline constexpr auto vtos = []<arithmetic T>(const T v) noexcept { if constexpr (same_as<Ct, char>) return std::to_string(v); else return std::to_wstring(v); };
inline constexpr overload strlen{[](const character auto* const Str) { return std::char_traits<cat1>::length(Str); }, []<range Rg>(Rg&& Str) requires character<iter_value<Rg>> { return std::ranges::distance(Str); }};

/// @brief source location
struct source {
  const char* const file;
  const int line, column;
  source(const char* const) = delete;
  constexpr source(const char* const File = __builtin_FILE(), const int Line = __builtin_LINE(), const int Column = __builtin_COLUMN()) noexcept : file(mv(File)), line(Line), column(Column) {}
  std::string to_string() const { return std::format("{}({},{})", file, line, column); }
  template<typename Tr> friend std::basic_ostream<char, Tr>& operator<<(std::basic_ostream<char, Tr>& os, const source& s) { return os << s.to_string(); }
};

/// @brief file path
class path : public std::filesystem::path {
public:
  path() noexcept = default;
  path(const std::filesystem::path& p) : std::filesystem::path(p) {}
  path(std::filesystem::path&& p) noexcept : std::filesystem::path(mv(p)) {}
  path(string_type&& s) : std::filesystem::path(mv(s)) {}
  template<range Rg> requires character<iter_value<Rg>> path(Rg&& r) : std::filesystem::path(yw::begin(r), yw::end(r)) {}
  template<character Ct> path(const Ct* s) : std::filesystem::path(s) {}
  bool exists() const { return std::filesystem::exists(*this); }
  bool is_file() const { return std::filesystem::is_regular_file(*this); }
  bool is_directory() const { return std::filesystem::is_directory(*this); }
  nat file_size() const { return std::filesystem::file_size(*this); }
  std::vector<path> list(bool Recursive = false) const {
    std::vector<path> A;
    if (Recursive)
      for (const auto& E : std::filesystem::recursive_directory_iterator(*this)) A.push_back(E.path());
    else
      for (const auto& E : std::filesystem::directory_iterator(*this)) A.push_back(E.path());
    return A;
  }
  void read(cnt_range auto& Out) const requires(!is_const<decltype(yw::data(Out))>) {
    if (const auto n = yw::size(Out) * sizeof(iter_value<decltype(Out)>); file_size() == n) {
      if (std::ifstream ifs(*this, std::ios::binary); ifs) return void(ifs.read(reinterpret_cast<char*>(yw::data(Out)), n));
      auto text = std::format("Error: failed to open the file ({}\n at {}({},{})", );
      throw std::exception(text.c_str());
    }
    auto text = std::format("Error: byte size of `Out` is not equal to the file size ({}\n at {}({},{})", );
    throw except("byte size of `Out` is not equal to the file size");
  }
  void write(cnt_range auto&& In) const { write(yw::data(In), yw::size(In) * sizeof(iter_value<decltype(In)>)); }
  void write(const void* In, nat Size) const {
    if (std::ofstream ofs(*this, std::ios_base::binary); ofs) ofs.write(reinterpret_cast<const char*>(In), Size);
    else throw except("failed to open the file");
  }
  void remove() const { std::filesystem::remove(*this); }
};
