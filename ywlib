struct t_to_utf16 {
  /// Convert a utf-8 string to utf-16 string.
  string<uct2> operator()(const string_view<uct1>& utf8) const {
    if (utf8.empty()) return {};
    if (auto size = ::MultiByteToWideChar(CP_UTF8, 0, reinterpret_cast<const cat1*>(utf8.data()), -1, nullptr, 0); size) {
      string<uct2> utf16(size - 1, L'\0');
      ::MultiByteToWideChar(CP_UTF8, 0, reinterpret_cast<const cat1*>(utf8.data()), -1, reinterpret_cast<cat2*>(utf16.data()), size);
      return utf16;
    } else return {};
  }
  /// Convert a utf-16 string to utf-16 string.
  constexpr string<uct2> operator()(const string_view<uct2>& wcs) const {
    return string<uct2>(wcs);
  }
  /// Convert a utf-32 string to utf-16 string.
  constexpr string<uct2> operator()(const string_view<uct4>& utf32) const {
    string<uct2> utf16(utf32.size() * 2, u'\0');
    nat size = 0;
    for (auto i = utf32.begin(); i < utf32.end(); ++i) {
      if (*i < 0x10000) utf16[size++] = uct2(*i);
      else if (*i < 0x110000) {
        utf16[size++] = uct2(0xD800 + (*i - 0x10000) / 0x400);
        utf16[size++] = uct2(0xDC00 + (*i - 0x10000) % 0x400);
      } else break; }
    utf16.resize(size); return utf16;
  }
  /// Convert a multi-byte-string to utf-16 string.
  string<uct2> operator()(const string_view<cat1>& mbs) const {
    if (mbs.empty()) return {};
    if (auto size = ::MultiByteToWideChar(CP_ACP, 0, mbs.data(), -1, nullptr, 0); size) {
      string<uct2> utf16(size - 1, L'\0');
      ::MultiByteToWideChar(CP_ACP, 0, mbs.data(), -1, reinterpret_cast<cat2*>(utf16.data()), size);
      return utf16;
    } else return {};
  }
  /// Convert a wide-char-string to utf-16 string.
  string<uct2> operator()(const string_view<cat2>& wcs) const {
    return string<uct2>(reinterpret_cast<const string_view<uct2>&>(wcs));
  } };
