// CASTER //////////////////////////////////////////////////////////////////////

/// @brief structure that can be converted to types through functions
template<typename... Fs> requires((requires(Fs&& f) { f(); }) && ...) struct caster : public Fs... {
private:
  static constexpr size_t n = sizeof...(Fs);
  template<typename T> static constexpr size_t j = inspects<same_as<T, decltype(Fs{}())>...>;
  template<typename T> static constexpr size_t i = j<T> < n ? j<T> : inspects<convertible_to<decltype(Fs::operator()()), T>...>;
  template<typename T> static constexpr bool nothrow = j<T> < n || nt_convertible_to<decltype(type_switch<i<T>, Fs...>::operator()()), T>;
public:
  template<typename T> requires(i<T> < n) constexpr operator T() const noexcept(nothrow<T>) { return type_switch<i<T>, Fs...>::operator()(); }
};

/// @brief structure that can be converted to a type through a function
template<typename F> struct caster<F> : public F {
  constexpr operator decltype(auto)() const noexcept(noexcept(F::operator()())) { return F::operator()(); }
};

/// @brief checks if the current context is constant evaluated
