/// @brief class for logging text; the text is written to a file when the object is destroyed.
class logger {
  string<cat1> text;
  path file;
public:
  /// @brief constructs a logger object with the specified file name to write the text to.
  logger(const path& LogFileName) : file(LogFileName) {}
  /// @brief saves the text to the file.
  ~logger() { if (std::ofstream ofs(file, std::ios::app); ofs) ofs << text << std::endl; }
  /// @brief appends the text to the logger object.
  logger& operator<<(const string_view<cat1> s) { return (text += s) += "\n", *this; }
  /// @brief outputs the text of the logger object to the specified output stream.
  template<typename Tr> friend std::basic_ostream<cat1, Tr>& operator<<(std::basic_ostream<cat1, Tr>& os, const logger& l) { return os << l.text; }
};

