namespace _ { // clang-format off
#ifdef ywlib_memo_size
inline constexpr size_t _memo_size = ywlib_memo_size
#else
inline constexpr size_t _memo_size = 1024 * 1024;
#endif
#ifdef ywlib_memo_align
inline constexpr size_t _memo_align = ywlib_memo_align;
#else
inline constexpr size_t _memo_align = 16;
#endif
inline char _memo[_memo_size];
inline size_t _memo_offset{};
} // clang-format on

/// @brief allocates memory for momentary memos
template<typename T, size_t N = 1> requires(0 < sizeof(T) * N && sizeof(T) * N <= _::_memo_size)
inline constexpr caster memo{[]() noexcept -> T* {
  static constexpr size_t l = _::_memo_align, m = sizeof(T) * N, n = m % l ? m + l - m % l : m;
  if (_::_memo_offset + n <= _::_memo_size) {
    auto p = reinterpret_cast<T*>(_::_memo + _::_memo_offset);
    return _::_memo_offset += n, p;
  } else return _::_memo_offset = n, reinterpret_cast<T*>(_::_memo); }};


