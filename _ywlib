/// @brief selects a type from `Ts` by index `I`
template<convertible_to<size_t> auto I, typename... Ts>
requires((is_bool<decltype(I)> && sizeof...(Ts) == 2) ||
         (!is_bool<decltype(I)> && static_cast<size_t>(I) < sizeof...(Ts)))
using type_switch = typename _::_type_switch<decltype(I), I, Ts...>::type;

/// @brief selects a constant from `Vs` by index `I`
template<convertible_to<size_t> auto I, auto... Vs>
requires((is_bool<decltype(I)> && sizeof...(Vs) == 2) ||
         (!is_bool<decltype(I)> && static_cast<size_t>(I) < sizeof...(Vs)))
inline constexpr auto value_switch = type_switch<I, constant<Vs...>>::value;

/// @brief selects a parameter from `Args` by index `I`
template<convertible_to<size_t> auto I>
inline constexpr auto parameter_switch = []<typename A, typename... As>(A&& Arg, As&&... Args) noexcept
  -> decltype(auto) requires((is_bool<decltype(I)> && sizeof...(Args) == 1) ||
                             (!is_bool<decltype(I)> && static_cast<size_t>(I) <= sizeof...(Args))) {
    if constexpr (is_bool<decltype(I)>) {
      return parameter_switch<size_t(!I)>(static_cast<A&&>(Arg), static_cast<As&&>(Args)...);
    } else if constexpr (same_as<decltype(I), size_t>) {
      if constexpr (I == 0) return static_cast<A&&>(Arg);
      else return parameter_switch<I - 1>(static_cast<As&&>(Args)...);
    } else return parameter_switch<size_t(I)>(static_cast<A&&>(Arg), static_cast<As&&>(Args)...); };

