/// @brief base class for GPU buffers
template<typename T> class buffer {
protected:
  comptr<ID3D11Buffer> d3d_buffer;
  buffer(const buffer&) = delete;
  buffer& operator=(const buffer&) = delete;
  buffer(const numerical auto Count) noexcept : count(unsigned(Count)) {}
public:
  using value_type = T;
  const unsigned count{};
  buffer() noexcept = default;
  buffer(buffer&& B) noexcept : d3d_buffer{mv(B.d3d_buffer)}, count{B.count} {}
  buffer& operator=(buffer&& B) noexcept {
    d3d_buffer = mv(B.d3d_buffer);
    const_cast<unsigned&>(count) = B.count;
    return *this;
  }
  explicit operator bool() const noexcept { return bool(d3d_buffer); }
  operator ID3D11Buffer*() const noexcept { return d3d_buffer; }
  void from(const buffer& Src) {
    tiff(d3d_buffer, "this buffer is not initialized");
    tiff(count == Src.count, "the size of the source buffer must be the same as this buffer");
    main::d3d_context->CopyResource(*this, Src);
  }
  virtual std::vector<T> to_cpu() const;
  virtual std::vector<T> to_cpu(staging_buffer<T>& Staging) const;
};

/// @brief staging buffer class
template<typename T> class staging_buffer : public buffer<T> {
public:
  staging_buffer() noexcept = default;
  explicit staging_buffer(const buffer<T>& Src) : staging_buffer(Src.count) { buffer<T>::from(Src); }
  explicit staging_buffer(numerical auto Count) : buffer<T>(Count) {
    D3D11_BUFFER_DESC desc{unsigned(sizeof(T) * Count), D3D11_USAGE_STAGING, 0, D3D11_CPU_ACCESS_READ};
    tiff(main::d3d_device->CreateBuffer(&desc, nullptr, buffer<T>::d3d_buffer.init()));
  }
  virtual std::vector<T> to_cpu() const {
    tiff(*this, "this buffer is not valid");
    D3D11_MAPPED_SUBRESOURCE mapped{};
    std::vector<T> a(buffer<T>::count);
    tiff(main::d3d_context->Map(*this, 0, D3D11_MAP_READ, 0, &mapped));
    std::memcpy(a.data(), mapped.pData, sizeof(T) * buffer<T>::count);
    main::d3d_context->Unmap(*this, 0);
    return a;
  }
};
template<typename T> staging_buffer(const buffer<T>&) -> staging_buffer<T>;

template<typename T> std::vector<T> buffer<T>::to_cpu() const {
  tiff(*this, "this buffer is not initialized");
  auto a = staging_buffer(*this);
  return a.to_cpu();
}

template<typename T> std::vector<T> buffer<T>::to_cpu(staging_buffer<T>& s) const {
  tiff(*this, "this buffer is not initialized");
  return s.from(*this), s.to_cpu();
}

/// @brief constant buffer class
template<typename T> requires((sizeof(T) & 0xf) == 0) class constant_buffer : public buffer<T> {
  static constexpr auto desc = D3D11_BUFFER_DESC(
    sizeof(T), D3D11_USAGE_DYNAMIC, D3D11_BIND_CONSTANT_BUFFER, D3D11_CPU_ACCESS_WRITE);
public:
  constant_buffer() noexcept = default;
  constant_buffer(const T& Value) : buffer<T>(1) {
    D3D11_SUBRESOURCE_DATA d(&Value);
    tiff(main::d3d_device->CreateBuffer(&desc, &d, buffer<T>::d3d_buffer.init()));
  }

  /// @brief constructor with a initial value
  template<typename U> requires assignable<T&, U> || vassignable<T&, U> constant_buffer(U&& Value) : buffer<T>(1) {
    tiff(main::d3d_device->CreateBuffer(&desc, nullptr, buffer<T>::d3d_buffer.init()));
    this->from(fwd<U>(Value));
  }

  /// loads the new data to this buffer
  template<typename U> requires assignable<T&, U> || vassignable<T&, U> void from(U&& Value) {
    if (*this) {
      D3D11_MAPPED_SUBRESOURCE mapped;
      tiff(main::d3d_context->Map(*this, 0, D3D11_MAP_WRITE_DISCARD, 0, &mapped));
      if constexpr (assignable<T&, U>) *reinterpret_cast<T*>(mapped.pData) = fwd<U>(Value);
      else vassign(*reinterpret_cast<T*>(mapped.pData), fwd<U>(Value));
      main::d3d_context->Unmap(*this, 0);
    } else {
      T temp;
      if constexpr (assignable<T&, U>) *this = constant_buffer(temp = fwd<U>(Value));
      else vassign(temp, fwd<U>(Value)), *this = constant_buffer(temp);
    }
  }

  /// copies the new data to this buffer throw a function
  void from(invocable<T&> auto&& Func) {
    tiff(buffer<T>::operator bool(), "this buffer is not valid");
    D3D11_MAPPED_SUBRESOURCE mapped;
    tiff(main::d3d_context->Map(*this, 0, D3D11_MAP_WRITE_DISCARD, 0, &mapped));
    Func(*reinterpret_cast<T*>(mapped.pData)), main::d3d_context->Unmap(*this, 0);
  }
  void to_vs(nat Slot = 0) const {
    tiff(buffer<T>::operator bool(), "this buffer is not valid");
    auto p = buffer<T>::d3d_buffer.get();
    main::d3d_context->VSSetConstantBuffers(unsigned(Slot), 1, &p);
  }
  void to_gs(nat Slot = 0) const {
    tiff(buffer<T>::operator bool(), "this buffer is not valid");
    auto p = buffer<T>::d3d_buffer.get();
    main::d3d_context->GSSetConstantBuffers(unsigned(Slot), 1, &p);
  }
  void to_ps(nat Slot = 0) const {
    tiff(buffer<T>::operator bool(), "this buffer is not valid");
    auto p = buffer<T>::d3d_buffer.get();
    main::d3d_context->PSSetConstantBuffers(unsigned(Slot), 1, &p);
  }
  void to_cs(nat Slot = 0) const {
    tiff(buffer<T>::operator bool(), "this buffer is not valid");
    auto p = buffer<T>::d3d_buffer.get();
    main::d3d_context->CSSetConstantBuffers(unsigned(Slot), 1, &p);
  }
};
template<typename T> constant_buffer(const T&) -> constant_buffer<T>;

