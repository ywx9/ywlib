template<int VirtualKey> requires(1 <= VirtualKey && VirtualKey <= 254) struct key {
  inline static constexpr int code = VirtualKey;
  inline static constexpr caster changed{[]() noexcept -> bool { return main::system::keyboard_state[2][code] & 0x08; }};
  inline static constexpr caster pushed{[]() noexcept -> bool { return main::system::keyboard_state[2][code] & 0x80; }};
  constexpr operator bool() const noexcept { return main::system::keyboard_state[2][code] & 0x80; };
  inline static constexpr caster free{[]() noexcept -> bool { return (main::system::keyboard_state[2][code] & 0x88) == 0; }};
  inline static constexpr caster up{[]() noexcept -> bool { return (main::system::keyboard_state[2][code] & 0x88) == 0x08; }};
  inline static constexpr caster down{[]() noexcept -> bool { return (main::system::keyboard_state[2][code] & 0x88) == 0x88; }};
  inline static constexpr caster hold{[]() noexcept -> bool { return (main::system::keyboard_state[2][code] & 0x88) == 0x80; }};
};

