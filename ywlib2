/// @brief source location
struct source {
  const char* const file;
  const int line, column;
  source(const char* const) = delete;
  constexpr source(const char* const File = __builtin_FILE(), const int Line = __builtin_LINE(), const int Column = __builtin_COLUMN()) noexcept : file(mv(File)), line(Line), column(Column) {}
  std::string to_string() const { return std::format("{}({},{})", file, line, column); }
  template<typename Tr> friend std::basic_ostream<char, Tr>& operator<<(std::basic_ostream<char, Tr>& os, const source& s) { return os << s.to_string(); }
};

/// @brief exception handler
struct except {
  const std::exception& e;
  /// @brief receives the exception and displays the message
  void receive(const source& _ = {}) const {
    auto text = std::format("{}\n at {}({},{})", e.what(), _.file, _.line, _.column);
    std::cerr << text << std::endl;
    ::MessageBoxA(nullptr, text.data(), "Exception", 0x00000030L);
  }
  /// @brief appends the source location and rethrows the exception
  void reray(const source& _ = {}) const {
    auto text = std::format("{}\n at {}({},{})", e.what(), _.file, _.line, _.column);
    throw std::exception(text.data());
  }
};

/// @brief file path
class path : public std::filesystem::path {
public:
  path() noexcept = default;
  path(const std::filesystem::path& p) : std::filesystem::path(p) {}
  path(std::filesystem::path&& p) noexcept : std::filesystem::path(mv(p)) {}
  path(string_type&& s) : std::filesystem::path(mv(s)) {}
  template<range Rg> requires character<iter_value<Rg>> path(Rg&& r) : std::filesystem::path(yw::begin(r), yw::end(r)) {}
  template<character Ct> path(const Ct* s) : std::filesystem::path(s) {}
  bool exists() const { return std::filesystem::exists(*this); }
  bool is_file() const { return std::filesystem::is_regular_file(*this); }
  bool is_directory() const { return std::filesystem::is_directory(*this); }
  nat file_size() const { return std::filesystem::file_size(*this); }

  /// @brief lists the files in the directory
  /// @param Recursive if true, lists the files recursively
  std::vector<path> list(bool Recursive = false, const source& _ = {}) const {
    if (!is_directory()) throw std::runtime_error(std::format("runtime error: the path is not a directory ({})\n at {}({},{})", static_cast<const std::filesystem::path&>(*this), _.file, _.line, _.column));
    std::vector<path> A;
    if (Recursive)
      for (const auto& E : std::filesystem::recursive_directory_iterator(*this)) A.push_back(E.path());
    else
      for (const auto& E : std::filesystem::directory_iterator(*this)) A.push_back(E.path());
    return A;
  }
  /// @brief reads the file content into the output range
  /// @exception `std::runtime_error` if the file cannot be opened
  /// @exception `std::runtime_error` if the byte size of `Out` is not equal to the file size
  void read(cnt_range auto& Out, const source& _ = {}) const requires(!is_const<decltype(yw::data(Out))>) {
    if (const auto n = yw::size(Out) * sizeof(iter_value<decltype(Out)>); file_size() == n) {
      if (std::ifstream ifs(*this, std::ios::binary); ifs) return void(ifs.read(reinterpret_cast<char*>(yw::data(Out)), n));
      throw std::runtime_error(std::format("runtime error: failed to open the file ({})\n at {}({}, {})", static_cast<const std::filesystem::path&>(*this), _.file, _.line, _.column));
    } else throw std::runtime_error(std::format("runtime error: the byte size of the output range is not equal to the file size ({})\n at {}({}, {})", static_cast<const std::filesystem::path&>(*this), _.file, _.line, _.column));
  }

  /// @brief writes the input range content to the file
  /// @exception `std::runtime_error` if the file cannot be opened
  void write(cnt_range auto&& In, const source& _ = {}) const {
    if (std::ofstream ofs(*this, std::ios::binary); ofs) ofs.write(reinterpret_cast<const char*>(yw::data(In)), yw::size(In) * sizeof(iter_value<decltype(In)>));
    else throw std::runtime_error(std::format("runtime error: failed to open the file ({})\n at {}({}, {})", static_cast<const std::filesystem::path&>(*this), _.file, _.line, _.column));
  }

  /// @brief removes the file
  void remove() const { std::filesystem::remove(*this); }
};

