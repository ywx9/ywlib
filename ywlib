template<typename Sq, typename Tp> concept sequence_for = requires {
  requires tuple<Tp>; requires sequence_of<Sq, nat>; requires _::_sequence_for<to_sequence<Sq>, extent<Tp>>::value; };
/// @brief makes `sequence` with elements from `Proj(Begin)` to `Proj(End - 1)`.
template<nat End, nat Begin = 0, invocable<nat> auto Proj = pass{}> requires(Begin <= End)
using make_sequence = typename _::_make_sequence<End, Begin, Proj>::type;
/// @brief makes `sequence` with elements from `0` to `extent<Tp> - 1`.
template<typename Tp> using make_sequence_for = make_sequence<extent<Tp>>;
/// @brief makes `sequence` with indices where `Bs...` are `true`.
template<sequence_of<bool> Sq> using extract_sequece =
  typename _::_extract_sequece<0, extent<to_sequence<Sq, bool>>, to_sequence<Sq, bool>>::type;
