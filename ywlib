class path : public std::filesystem::path {
public:
  path() noexcept = default;
  path(const std::filesystem::path& p) : std::filesystem::path(p) {}
  path(std::filesystem::path&& p) noexcept : std::filesystem::path(mv(p)) {}
  path(string_type&& s) : std::filesystem::path(mv(s)) {}
  template<range Rg> requires character<iter_value<Rg>> path(Rg&& r) : std::filesystem::path(yw::begin(r), yw::end(r)) {}
  template<character Ct> path(const Ct* s) : std::filesystem::path(s) {}
  bool exists() const { return std::filesystem::exists(*this); }
  bool is_file() const { return std::filesystem::is_regular_file(*this); }
  bool is_directory() const { return std::filesystem::is_directory(*this); }
  nat file_size() const { return std::filesystem::file_size(*this); }
  std::vector<path> list(bool Recursive = false, const source& _ = {}) const {
    if (!exists()) throw std::runtime_error(std::format("runtime error in path::list : the path does not exist ({})", this->string()));
    if (!is_directory()) throw std::runtime_error(std::format("runtime error in path::list: the path is not a directory ({})", this->string()));
    std::vector<path> A;
    if (Recursive) for (const auto& E : std::filesystem::recursive_directory_iterator(*this)) A.push_back(E.path());
    else for (const auto& E : std::filesystem::directory_iterator(*this)) A.push_back(E.path());
    return A;
  }
  void read(cnt_range auto& Out, const source& _ = {}) const requires(!is_const<decltype(yw::data(Out))>) {
    if (const auto n = yw::size(Out) * sizeof(iter_value<decltype(Out)>); file_size() == n) {
      if (std::ifstream ifs(*this, std::ios::binary); ifs) return void(ifs.read(reinterpret_cast<char*>(yw::data(Out)), n));
      else throw std::runtime_error(std::format("runtime error in path::read : failed to open the file ({})", this->string()));
    } else throw std::runtime_error(std::format("runtime error in path::read : the byte size of the output range is not equal to the file size ({})", this->string()));
  }
  std::string read(const source& _ = {}) const { std::string a(file_size(), char{}); return read(a, _), mv(a); }
  void write(cnt_range auto&& In, const source& _ = {}) const {
    if (std::ofstream ofs(*this, std::ios::binary); ofs) ofs.write(reinterpret_cast<const char*>(yw::data(In)), yw::size(In) * sizeof(iter_value<decltype(In)>));
    else throw std::runtime_error(std::format("runtime error in path::write : failed to open the file ({})", this->string()));
  }
  void remove() const { std::filesystem::remove(*this); }
};
}

