inline constexpr auto xmtranspose = []<xm Xm, xm XmT>(const Xm& M, XmT& O) noexcept
  requires (le(extent<Xm>, 4) && le(extent<XmT>, 4) && same_as<remove_cvref<element_t<Xm, 0>>, remove_cvref<element_t<XmT, 0>>>) {
  constexpr auto f = []<nat I>(constant<I>, const auto& A, auto& B) noexcept {
    if constexpr (extent<Xm> == 1) B = xvinsert<0, I, 0b1110>(get<0>(A), get<0>(A));
    B = xvpermute<I, 4 + I, -1, -1>(get<0>(A), get<1>(A));
    if constexpr (extent<Xm> == 2) B = xvsetzero<0, 0, 1, 1>(B);
    else if constexpr (extent<Xm> == 3) B = xvinsert<2, I, 0b1000>(B, get<2>(A));
    else if constexpr (extent<Xm> == 4) B = xvpermute<0, 1, 4, 5>(B, xvpermute<I, 4 + I, -1, -1>(get<2>(M), get<3>(M))); };
  []<nat... Is>(sequence<Is...>) noexcept { (f(constant<Is>{}, M, get<Is>(O)), ...); }(make_indices_for<XmT>{}); };

inline constexpr auto xmtranslate = []<xv Xv, xm Xm>(const Xv& Offset, Xm& O) noexcept
  requires (le(extent<Xm>, 4) && same_as<Xv, remove_cvref<element_t<Xm, 0>>>) {
