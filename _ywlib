namespace yw {

namespace _::_get { // clang-format off
template<size_t I> void get(auto&&) = delete;
template<size_t I, typename T> inline constexpr auto pattern = []() -> int4 {
  if constexpr (is_bounded_array<remove_ref<T>> && I < std::extent_v<remove_ref<T>>) return 4;
  else if constexpr (requires { get<I>(declval<T>()); }) return 1 | noexcept(get<I>(declval<T>())) * 4;
  else if constexpr (requires { declval<T>().template get<I>(); }) return 2 | noexcept(declval<T>().template get<I>()) * 4;
  else return 8; }();
template<size_t I, typename T, size_t P = pattern<I, T>> requires(P < 8)
constexpr decltype(auto) call(T&& A) noexcept(bool(P & 4)) {
  if constexpr ((P & 3) == 0) return static_cast<T&&>(A)[I];
  else if constexpr ((P & 3) == 1) return get<I>(static_cast<T&&>(A));
  else if constexpr ((P & 3) == 2) return static_cast<T&&>(A).template get<I>(); }
template<typename T> inline constexpr size_t extent = type_switch<
  inspects<is_array<T>, requires { std::tuple_size<T>::value; }>,
  std::extent<T>, std::tuple_size<T>, constant<0_nn>>::value; } // clang-format on

/// @brief returns the `I`-th element of `Tuple`
template<size_t I> inline constexpr auto get = []<typename Tp>(Tp&& Tuple)
  ywlib_wrapper(_::_get::call<I>(static_cast<Tp&&>(Tuple)));

/// @brief checks if `get<I>(Tp)` is valid
template<typename Tp, size_t I> concept gettable = requires { get<I>(declval<Tp>()); };

/// @brief checks if `get<I>(Tp)` is valid and noexcept
template<typename Tp, size_t I> concept nt_gettable = requires {
  requires gettable<Tp, I>;
  { get<I>(declval<Tp>()) } noexcept; };

/// @brief alias template representing the `I`-th element type of `Tp`
template<typename Tp, size_t I> requires gettable<Tp, I> using element_t = decltype(get<I>(declval<Tp>()));

/// @brief tuple size
template<typename Tp> inline constexpr size_t extent = _::extent<remove_ref<Tp>>;


template<auto... Vs> struct sequence;
template<typename... Ts> struct typepack;
template<typename... Ts> struct list;

namespace _ { // clang-format off
template<typename S, typename T = none> struct _to_sequence { using type = none; };
template<template<auto...> typename Tm, typename T, auto... Vs> struct _to_sequence<Tm<Vs...>, T> { using type = sequence<T(Vs)...>; };
template<template<typename, auto...> typename Tm, typename T, typename U, auto... Vs> struct _to_sequence<Tm<U, Vs...>, T> { using type = sequence<T(Vs)...>; };
template<template<auto...> typename Tm, auto... Vs> struct _to_sequence<Tm<Vs...>, none> { using type = sequence<Vs...>; };
template<template<typename, auto...> typename Tm, typename U, auto... Vs> struct _to_sequence<Tm<U, Vs...>, none> { using type = sequence<Vs...>; };
template<typename S, size_t N> struct _indices_for : constant<false> {};
template<size_t... Is, size_t N> struct _indices_for<sequence<Is...>, N> : constant<(lt(Is, N) && ...)> {};
template<size_t End, size_t Begin = 0, std::invocable<size_t> auto Proj = pass{}, size_t... Vs>
struct _make_sequence : _make_sequence<End, Begin + 1, Proj, Vs..., Proj(Begin)> {};
template<size_t End, auto Proj, size_t... Vs> struct _make_sequence<End, End, Proj, Vs...> { using type = sequence<Vs...>; };
template<size_t I, size_t N, typename S, typename... T> struct _comb_indices;
template<size_t I, size_t N, bool... Bs, size_t... Is> struct _comb_indices<I, N, sequence<Bs...>, sequence<Is...>>
  : _comb_indices<I + 1, N, sequence<Bs...>, type_switch<value_switch<I, Bs...>, sequence<Is..., I>, sequence<Is...>>> {};
template<size_t N, bool... Bs, size_t... Is> struct _comb_indices<N, N, sequence<Bs...>, sequence<Is...>> : trait<sequence<Is...>> {};
template<typename T, typename S> struct _to_typepack;
template<typename T, size_t... Is> struct _to_typepack<T, sequence<Is...>> : trait<typepack<element_t<T, Is>...>> {};
} // clang-format on

template<typename Sq, typename T = none> using to_sequence = typename _::_to_sequence<Sq, T>::type;

template<typename Sq, typename T = none> concept sequence_of = !is_none<to_sequence<Sq, T>>;

template<typename Sq, typename Tp> concept indices_for = requires {
  requires sequence_of<Sq, size_t>;
  requires _::_indices_for<to_sequence<Sq>, extent<Tp>>::value; };

/// @brief returns `sequence<Is...>` where `Is = {Proj(Begin), ..., Proj(End - 1)}`
template<size_t End, size_t Begin = 0, std::invocable<size_t> auto Proj = pass{}> requires(Begin <= End)
using make_sequence = typename _::_make_sequence<End, Begin, Proj>::type;

/// @brief returns `sequence<Is...>` where `Is = [0, extent<Tp>)`
template<typename Tp> using make_indices_for = make_sequence<extent<Tp>>;

/// @brief returns `sequence<Is...>` where `{Is | Sq.at<Is> == true}`
template<sequence_of<bool> Sq> using cond_indices =
  typename _::_cond_indices<0, extent<to_sequence<Sq, bool>>, to_sequence<Sq, bool>, sequence<>>::type;

/// @brief returns `typepack<Ts...>` where `Ts = {element_t<Tp, Is>...}`
template<typename Tp> using to_typepack = typename _::_to_typepack<Tp, make_indices_for<Tp>>::type;


/// @brief general value sequence
template<auto... Vs> struct sequence {
private: // clang-format off
  template<typename S> struct _append : _append<to_sequence<S, none>> {};
  template<auto... Ws> struct _append<sequence<Ws...>> { using type = sequence<Vs..., Ws...>; };
  template<> struct _append<none> { using type = none; };
  template<typename S> struct _pickup : _pickup<to_sequence<S, none>> {};
  template<size_t... Is> struct _pickup<sequence<Is...>> { using type = sequence<value_switch<Is, Vs...>...>; };
  template<> struct _pickup<none> { using type = none; };
public: // clang-format on

  static constexpr size_t count = sizeof...(Vs);
  template<size_t I> requires(lt(I, count)) static constexpr auto at = value_switch<I, Vs...>;
  template<size_t I> requires(lt(I, count)) using type_at = type_switch<I, decltype(Vs)...>;
  template<sequence_of Sq> using append = typename _append<to_sequence<Sq>>::type;
  template<indices_for<sequence> Sq> using pickup = typename _pickup<to_sequence<Sq, size_t>>::type;
  template<size_t N> requires(N < count) using fore = pickup<make_sequence<N>>;
  template<size_t N> requires(N < count) using back = pickup<make_sequence<count, count - N>>;
  template<size_t I, sequence_of Sq> requires(I < count) using insert = typename fore<I>::template append<Sq>::template append<back<count - I>>;
  template<template<auto...> typename Tm> using expand = Tm<Vs...>;
  template<size_t I> requires(I < count) constexpr const auto&& get() const noexcept { return mv(at<I>); }
};


/// @brief general type sequence
template<typename... Ts> struct typepack {
private:
  template<typename T, typename U> struct t_append {};
  template<typename... Us, typename... Vs> struct t_append<typepack<Us...>, typepack<Vs...>> : trait<typepack<Us..., Vs...>> {};
  template<typename T, typename S> struct t_pickup {};
  template<typename... Us, size_t... Is> struct t_pickup<typepack<Us...>, sequence<Is...>> : trait<typepack<type_switch<Is, Us...>...>> {};
public:

  static constexpr size_t count = sizeof...(Ts);
  using common = common_type<Ts...>;
  template<size_t I> requires(I < count) using at = type_switch<I, Ts...>;
  template<typename T> using append = typename t_append<typepack, to_typepack<T>>::type;
  template<indices_for<typepack> S> using pickup = typename t_pickup<typepack, to_sequence<S, size_t>>::type;
  template<size_t N> requires(N <= count) using fore = pickup<make_sequence<N>>;
  template<size_t N> requires(N <= count) using back = pickup<make_sequence<count, count - N>>;
  template<size_t I, typename T> requires(I < count) using insert = typename fore<I>::template append<T>::template append<back<count - I>>;
  template<template<typename...> typename Tm> using expand = Tm<Ts...>;
  template<size_t I> requires(I < count) constexpr at<I> get() const noexcept;
};

