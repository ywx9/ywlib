struct value {
  double _{};
  constexpr value() noexcept = default;
  explicit constexpr value(none) noexcept : _(std::bit_cast<double>(0x7ff8000000000001)) {}
  template<castable_to<double> T> constexpr value(T&& Value) noexcept : _(static_cast<double>(Value)) {}
  constexpr operator const double&() const noexcept { return _; }
  template<typename T> requires castable_to<double, T> explicit operator T() const noexcept { return static_cast<T>(_); }
  template<castable_to<double> T> constexpr value& operator+=(T&& Value) noexcept { return _ += static_cast<double>(fwd<T>(Value)), *this; }
  template<castable_to<double> T> constexpr value& operator-=(T&& Value) noexcept { return _ -= static_cast<double>(fwd<T>(Value)), *this; }
  template<castable_to<double> T> constexpr value& operator*=(T&& Value) noexcept { return _ *= static_cast<double>(fwd<T>(Value)), *this; }
  template<castable_to<double> T> constexpr value& operator/=(T&& Value) noexcept { return _ /= static_cast<double>(fwd<T>(Value)), *this; }
};

