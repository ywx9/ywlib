struct value {
  fat _{};
  constexpr value() noexcept = default;
  explicit constexpr value(none) noexcept : _(bitcast<fat>(0x7ff8000000000001)) {}
  template<numerical T> requires(!same_as<T, value>) constexpr value(T&& Value) noexcept : _(fat(fwd<T>(Value))) {}
  constexpr operator const fat&() const noexcept { return _; }
  template<typename T> requires castable_to<fat, T> explicit operator T() const noexcept { return T(_); }
  template<numerical T> constexpr value& operator+=(T&& Value) noexcept { return _ += fat(fwd<T>(Value)), *this; }
  template<numerical T> constexpr value& operator-=(T&& Value) noexcept { return _ -= fat(fwd<T>(Value)), *this; }
  template<numerical T> constexpr value& operator*=(T&& Value) noexcept { return _ *= fat(fwd<T>(Value)), *this; }
  template<numerical T> constexpr value& operator/=(T&& Value) noexcept { return _ /= fat(fwd<T>(Value)), *this; }
};

