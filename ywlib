/// @brief basic tuple structure with no elements.
template<> struct list<> {
private:
  template<typename T, typename U, nat... Is, nat... Js>
  static constexpr auto _concat(T&& t, U&& u, sequence<Is...>, sequence<Js...>)
    ywlib_wrapper((yw::list{get<Is>(fwd<T>(t))..., get<Js>(fwd<U>(u))...}));
  template<typename T, typename U, typename V> struct _from_typepack {};
  template<typename... Ts, typename U, template<typename...> typename Tm, typename... Vs>
  struct _from_typepack<typepack<Ts...>, U, Tm<Vs...>> : std::type_identity<list<copy_cvref<Tm<Ts>, U>...>> {};
  template<typename... Ts, typename U, template<typename, auto...> typename Tm, typename V, auto... Vs>
  struct _from_typepack<typepack<Ts...>, U, Tm<V, Vs...>> : std::type_identity<list<copy_cvref<Tm<Ts, Vs...>, U>...>> {};
  template<typename... Ts, typename U, typename V>
  struct _from_typepack<typepack<Ts...>, U, V> : std::type_identity<list<copy_cvref<Ts, U>...>> {};
public:
  /// @brief number of elements.
  static constexpr nat count = 0;
  /// @brief concatenates two tuples.
  template<tuple T, tuple U> static constexpr auto concat(T&& Fore, U&& Back)
    ywlib_wrapper(_concat(fwd<T>(Fore), fwd<U>(Back), make_sequence_for<T>{}, make_sequence_for<U>{}));
  /// @brief makes a reference list.
  template<typename... Ts> static constexpr auto
  asref(Ts&&... Args) noexcept { return list<Ts&&...>{fwd<Ts>(Args)...}; }
  /// @brief makes a list from `typepack`
  /// @example `list::from_typepack<typepack<int, float>> -> list<int, float>`
  /// @example `list::from_typepack<typepack<int, float>, const int&> -> list<const int&, const float&>`
  /// @example `list::from_typepack<typepack<int, float>, std::vector<char>&> -> list<std::vector<int>&, std::vector<float>&>`
  template<specialization_of<typepack> Tp, typename Template = none>
  using from_typepack = _from_typepack<Tp, Template, remove_cvref<Template>>::type;
};

