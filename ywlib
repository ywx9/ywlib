/// show a file-open dialog
inline constexpr auto open_file = [](const path& Dir = {}) -> path {
  str2 buffer(256, '\0');
  OPENFILENAMEW ofn{DWORD(sizeof(OPENFILENAMEW)), main::hwnd, 0, L"All Files (*.*)\0", 0, 0, 1, buffer.data(), 256};
  ofn.lpstrInitialDir = Dir.c_str();
  ofn.Flags = OFN_FILEMUSTEXIST | OFN_PATHMUSTEXIST;
  return ::GetOpenFileNameW(&ofn) == TRUE ? path(ofn.lpstrFile) : path{};
};

/// show a file-save dialog
inline constexpr auto save_file = [](const path& Dir = {}, const path& Default = {}) noexcept -> path {
    str2 buffer(256, '\0');
    if (!Default.empty()) std::ranges::copy(Default.filename().wstring(), buffer.begin());
    OPENFILENAMEW ofn{DWORD(sizeof(OPENFILENAMEW)), main::hwnd, 0, L"All Files (*.*)\0", 0, 0, 1, buffer.data(), 256};
    ofn.lpstrInitialDir = Dir.c_str();
    ofn.Flags = OFN_OVERWRITEPROMPT | OFN_PATHMUSTEXIST;
    return ::GetSaveFileNameW(&ofn) == TRUE ? path(ofn.lpstrFile) : path{};
};

/// alignment
enum class alignment {lefttop, top, righttop, left, center, right, leftbottom, bottom, rightbottom};

/// @brief class to create a solid color brush object.
class solid_brush {
protected:
  comptr<ID2D1SolidColorBrush> brush{};
  void init(const rgb& Color) {
    if (!main::d2d_context) throw std::runtime_error("runtime error : yw::solid_brush : Direct2D is not initialized");
    if (!brush) tiff(main::d2d_context->CreateSolidColorBrush(reinterpret_cast<const D2D1_COLOR_F&>(Color), brush.init()));
  }
public:
  solid_brush() noexcept = default;
  explicit solid_brush(const rgb& Color) { init(Color); }
  explicit operator bool() const noexcept { return bool(brush); }
  operator ID2D1SolidColorBrush*() const noexcept { return brush; }
  /// @brief resets the color of the brush
  void color(const rgb& Color) { init(Color); }
  /// @brief returns the color of the brush
  rgb color() const { const auto c = brush->GetColor(); return reinterpret_cast<const rgb&>(c); }
};

/// text format to print plane text
template<value Size, rgb Color, literal<cat2> Font = L"Yu Gothic UI", bool Bold = false> class text_format {
  static void init() {
    try {
      if (!dw_format) {
        tiff(main::dw_factory->CreateTextFormat(
          Font, nullptr, Bold ? DWRITE_FONT_WEIGHT_BOLD : DWRITE_FONT_WEIGHT_NORMAL,
          DWRITE_FONT_STYLE_NORMAL, DWRITE_FONT_STRETCH_NORMAL, size, L"", dw_format.init()));
        tiff(dw_format->SetTextAlignment(DWRITE_TEXT_ALIGNMENT_LEADING));
      }
      if (!d2d_brush) tiff(main::d2d_context->CreateSolidColorBrush(D2D1::ColorF(D2D1::ColorF::Black), d2d_brush.init()));
      tiff(bool(dw_format), "Failed to initialize text format");
    } catch (const std::exception& e) {
      std::cerr << e.what() << '\n';
      throw std::runtime_error("runtime error: Failed to initialize text format");
    }
  }
  static list<fat4, fat4> get_metrics(const string_view<cat2>& Text) {
    comptr<IDWriteTextLayout> layout;
    tiff(main::dw_factory->CreateTextLayout(Text.data(), unsigned(Text.size()), dw_format, fat4(inf), fat4(inf), layout.init()));
    DWRITE_TEXT_METRICS metrics;
    layout->GetMetrics(&metrics);
    return {metrics.width, metrics.height};
  }
protected:
  inline static comptr<IDWriteTextFormat> dw_format{};
  inline static comptr<ID2D1SolidColorBrush> d2d_brush{};
public:
  static constexpr fat4 size = fat4(Size);
  static constexpr rgb color = Color;
  static constexpr auto font = Font;
  static constexpr auto bold = Bold;
  constexpr text_format() noexcept = default;
  explicit operator bool() const noexcept { return true; }
  /// return the geometry of the text; {width, height}
  static list<fat4, fat4> geometry(const string_view<cat2>& Text) {
    init();
    auto geometry = get_metrics(Text);
    return {geometry.first, geometry.second};
  }
  /// return the geometry of the text which is located at the specified position; {left, top, right, bottom}
  static vector geometry(const string_view<cat2>& Text, list<value, value> Point, alignment Align) {
    init();
    auto g = get_metrics(Text);
    auto w = fat4(Point.first), h = fat4(Point.second);
    switch (Align) {
    case alignment::lefttop: return {w, h, w + g.first, h + g.second};
    case alignment::top: return {w - g.first / 2, h, w + g.first / 2, h + g.second};
    case alignment::righttop: return {w - g.first, h, w, h + g.second};
    case alignment::left: return {w, h - g.second / 2, w + g.first, h + g.second / 2};
    case alignment::center: return {w - g.first / 2, h - g.second / 2, w + g.first / 2, h + g.second / 2};
    case alignment::right: return {w - g.first, h - g.second / 2, w, h + g.second / 2};
    case alignment::leftbottom: return {w, h - g.second, w + g.first, h};
    case alignment::bottom: return {w - g.first / 2, h - g.second, w + g.first / 2, h};
    case alignment::rightbottom: return {w - g.first, h - g.second, w, h};
    default: return {};
    } }
  /// Draws the text
  static void draw(const string_view<cat2>& Text, const vector& Rect) {
    init();
    main::d2d_context->DrawTextW(Text.data(), unsigned(Text.size()), dw_format, reinterpret_cast<const D2D1_RECT_F&>(Rect), d2d_brush);
  }
  /// Draws the text
  static void draw(const string_view<cat2>& Text, const value Left, const value Top) {
    init();
    auto geometry = get_metrics(Text);
    auto rect = D2D1::RectF(fat4(Left), fat4(Top), fat4(Left) + geometry.first, fat4(Top) + geometry.second);
    main::d2d_context->DrawTextW(Text.data(), unsigned(Text.size()), dw_format, rect, d2d_brush);
  }
};

/// @brief class to create a path geometry object.
class geometry {
protected:
  comptr<ID2D1PathGeometry> path{};
  void init() { if (!path) tiff(main::d2d_factory->CreatePathGeometry(path.init())); }
public:
  geometry() noexcept = default;
  geometry(const geometry&) = delete;
  geometry(geometry&&) noexcept = default;
  /// @brief draws the geometry
  void draw(convertible_to<ID2D1SolidColorBrush*> auto&& Brush, const value Thickness = 1.0) const {
    if (!path) throw std::runtime_error("runtime error : yw::geometry::draw : Path geometry is not initialized");
    main::d2d_context->DrawGeometry(path, Brush, fat4(Thickness));
  }
  /// @brief fills the geometry
  void fill(convertible_to<ID2D1SolidColorBrush*> auto&& Brush) const {
    if (!path) throw std::runtime_error("runtime error : yw::geometry::fill : Path geometry is not initialized");
    main::d2d_context->FillGeometry(path, Brush);
  }
  void add_line(const list<value, value>& Start, const list<value, value>& End) {
    init();
    comptr<ID2D1GeometrySink> sink;
    tiff(path->Open(sink.init()));
    sink->BeginFigure(D2D1::Point2F(fat4(Start.first), fat4(Start.second)), D2D1_FIGURE_BEGIN_FILLED);
    sink->AddLine(D2D1::Point2F(fat4(End.first), fat4(End.second)));
    sink->EndFigure(D2D1_FIGURE_END_OPEN);
    sink->Close();
  }
};

