/// @brief structure for measuring time
class stopwatch {
  inline static double freq = [](LARGE_INTEGER _) { return ::QueryPerformanceFrequency(&_), double(_.QuadPart); }({});
  mutable LARGE_INTEGER li;
  long long last;
public:
  stopwatch() noexcept : li{}, last{(::QueryPerformanceCounter(&li), li.QuadPart)} {}
  double operator()() const noexcept { return *this; }
  operator double() const noexcept { return ::QueryPerformanceCounter(&li), (li.QuadPart - last) / freq; }
  operator float() const noexcept { return float(operator double()); }
  void reset() noexcept { ::QueryPerformanceCounter(&li), last = li.QuadPart; }
  double split() noexcept { return ::QueryPerformanceCounter(&li), (li.QuadPart - exchange(last, li.QuadPart)) / freq; }
};

