inline constexpr auto eq = [](auto&& a, auto&& b) noexcept(noexcept(bool(a == b))) -> bool requires requires { { a == b } -> convertible_to<bool>; } { return a == b; };
inline constexpr auto ne = [](auto&& a, auto&& b) noexcept(noexcept(bool(a != b))) -> bool requires requires { { a != b } -> convertible_to<bool>; } { return a != b; };
inline constexpr auto lt = [](auto&& a, auto&& b) noexcept(noexcept(bool(std::less{}(a, b)))) -> bool requires requires { { a < b } -> convertible_to<bool>; } { return a < b; };
inline constexpr auto le = [](auto&& a, auto&& b) noexcept(noexcept(bool(std::less_equal{}(a, b)))) -> bool requires requires { { a <= b } -> convertible_to<bool>; } { return a <= b; };
inline constexpr auto gt = [](auto&& a, auto&& b) noexcept(noexcept(bool(a > b))) -> bool requires requires { { a > b } -> convertible_to<bool>; } { return a > b; };
inline constexpr auto ge = [](auto&& a, auto&& b) noexcept(noexcept(bool(a >= b))) -> bool requires requires { { a >= b } -> convertible_to<bool>; } { return a >= b; };

