namespace _::_get { // clang-format off
template<nat I> void get(auto&&) = delete;
template<nat I, typename T> inline constexpr auto pattern = []() -> int {
  if constexpr (is_bounded_array<remove_ref<T>> && I < std::extent_v<remove_ref<T>>) return 4;
  else if constexpr (requires { get<I>(declval<T>()); })
    return 1 | noexcept(get<I>(declval<T>())) * 4;
  else if constexpr (requires { declval<T>().template get<I>(); })
    return 2 | noexcept(declval<T>().template get<I>()) * 4;
  else return 8; }();
template<nat I, typename T, nat P = pattern<I, T>> requires(P < 8)
constexpr decltype(auto) call(T&& A) noexcept(bool(P & 4)) {
  if constexpr ((P & 3) == 0) return static_cast<T&&>(A)[I];
  else if constexpr ((P & 3) == 1) return get<I>(static_cast<T&&>(A));
  else if constexpr ((P & 3) == 2) return static_cast<T&&>(A).template get<I>(); }
template<typename T> using extent = type_switch<
  inspects<is_array<T>, requires { std::tuple_size<T>::value; }>, std::extent<T>, std::tuple_size<T>, constant<nat(0)>>;
} // clang-format on

/// @brief returns `I`-th element from `Tuple`.
template<nat I> inline constexpr auto get = []<typename Tp>(Tp&& Tuple)
  ywlib_wrapper(_::_get::call<I>(static_cast<Tp&&>(Tuple)));
/// @brief checks if `yw::get<I>(Tp)` is valid.
template<typename Tp, nat I> concept gettable = requires { get<I>(declval<Tp>()); };
/// @brief checks if `yw::get<I>(Tp)` is valid and noexcept.
template<typename Tp, nat I> concept nt_gettable =
  requires { requires gettable<Tp, I>; { get<I>(declval<Tp>()) } noexcept; };
/// @brief `I`-th element from `Tuple`.
template<typename Tp, nat I> requires gettable<Tp, I> using element_t = decltype(get<I>(declval<Tp>()));
/// @brief number of elements in `Tp`.
/// @note for user-defined types, it is necessary to define `std::tuple_size<Tp>`.
template<typename Tp> inline constexpr nat extent = _::_get::extent<remove_ref<Tp>>::value;
/// @brief checks if `Tp` is a tuple.
template<typename Tp> concept tuple = extent<Tp> != 0;
/// @brief checks if `T` has the same extent as `Tp`.
template<typename T, typename Tp> concept same_size = extent<T> == extent<Tp>;

