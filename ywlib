/// @brief generic value structure.
struct value {
  /// @brief value.
  fat8 value_{};
  /// @brief default constructor.
  constexpr value() noexcept = default;
  /// @brief constructor with `none`.
  constexpr value(none) noexcept : value_(std::numeric_limits<fat8>::quiet_NaN()) {}
  /// @brief constructor with a value.
  template<numerical T> requires(!same_as<T, value>)
  constexpr value(T&& Value) noexcept : value_(fat8(fwd<T>(Value))) {}
  /// @brief conversion to `double`.
  constexpr operator fat8() const noexcept { return value_; }
  /// @brief explicit conversion.
  template<typename T> requires castable_to<fat8, T>
  explicit constexpr operator T() const noexcept(nt_castable_to<fat8, T>) { return T(value_); }
  /// @brief addition assignment.
  template<numerical T> constexpr value& operator+=(T&& Value) noexcept { return _ += double(fwd<T>(Value)), *this; }
  /// @brief subtraction assignment.
  template<numerical T> constexpr value& operator-=(T&& Value) noexcept { return _ -= double(fwd<T>(Value)), *this; }
  /// @brief multiplication assignment.
  template<numerical T> constexpr value& operator*=(T&& Value) noexcept { return _ *= double(fwd<T>(Value)), *this; }
  /// @brief division assignment.
  template<numerical T> constexpr value& operator/=(T&& Value) noexcept { return _ /= double(fwd<T>(Value)), *this; }
};

