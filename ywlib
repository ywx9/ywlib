template<int X, int Y, int Z, int W> struct t_xvpermute {
  template<int A, int B, int C, int D> friend struct t_xvpermute;
private:
  template<included_in<xvector, xwector> Xv> static auto call(const Xv& A) noexcept {
    constexpr auto f = [](auto a, auto b) { return a == b || a < 0 || a >= 4; };
    constexpr nat x = (f(X, 0) ? 0 : X), y = (f(Y, 1) ? 1 : Y), z = (f(Z, 2) ? 2 : Z), w = (f(W, 3) ? 3 : W);
    if constexpr (f(X, 0) && f(Y, 1) && f(Z, 2) && f(W, 3)) return A;
    else if constexpr (f(X, 0) && f(Y, 0) && f(Z, 2) && f(W, 2) && same_as<Xv, xvector>) return _mm_moveldup_ps(A);
    else if constexpr (f(X, 1) && f(Y, 1) && f(Z, 3) && f(W, 3) && same_as<Xv, xvector>) return _mm_movehdup_ps(A);
    else if constexpr ((x | y) < 2 && 2 <= (z & w) && same_as<Xv, xwector>) return _mm256_permute_pd(A, int(x + y * 2 + (z - 2) * 4 + (w - 2) * 8));
    else if constexpr (same_as<Xv, xvector>) return _mm_permute_ps(A, int(x + y * 4 + z * 16 + w * 64));
