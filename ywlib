struct t_xvview {
  template<tuple_for<xvector> Matrix> requires (le(2, extent<Matrix>) && le(extent<Matrix>, 4))
  void operator()(const xvector& Radian, Matrix& O) const noexcept { return xvrotation_inv(Radian, O); }
