  []() noexcept -> const xwector& { static const xwector s = xvload(double(X), double(Y), double(Z), double(W)); return s; },
  []() noexcept -> const xrect& { static const xrect s = xvload(int(X), int(Y), int(Z), int(W)); return s; }};

