/// @brief shows a file open dialog
inline constexpr auto open_file = [](const std::filesystem::path& Dir = {}) noexcept -> std::filesystem::path {
  try {
    wchar_t* buffer = memo<wchar_t, 256>;
    OPENFILENAMEW ofn{DWORD(sizeof(OPENFILENAMEW)), main::hwnd, 0, L"All Files (*.*)\0", 0, 0, 1, buffer, 256};
    ofn.lpstrInitialDir = Dir.c_str();
    ofn.Flags = OFN_FILEMUSTEXIST | OFN_PATHMUSTEXIST;
    if (::GetOpenFileNameW(&ofn) == TRUE) return std::filesystem::path(ofn.lpstrFile);
  } catch (except E) { E.receive(); }
  return {};
};

/// @brief shows a file save dialog
inline constexpr auto save_file = [](const std::filesystem::path& Dir = {}, const std::filesystem::path& Default = {}) noexcept -> std::filesystem::path {
  try {
    wchar_t* buffer = memo<wchar_t, 256>;
    if (!Default.empty()) std::ranges::copy(Default.filename().wstring(), buffer);
    OPENFILENAMEW ofn{DWORD(sizeof(OPENFILENAMEW)), main::hwnd, 0, L"All Files (*.*)\0", 0, 0, 1, buffer, 256};
    ofn.lpstrInitialDir = Dir.c_str();
    ofn.Flags = OFN_OVERWRITEPROMPT | OFN_PATHMUSTEXIST;
    if (::GetSaveFileNameW(&ofn) == TRUE) return std::filesystem::path(ofn.lpstrFile);
  } catch (except E) { E.receive(); }
  return {};
};


