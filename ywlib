template<tuple Tp> using to_typepack = typename _::_to_typepack<Tp, make_sequence_for<Tp>>::type;

/// @brief checks if all elements of `Tp` are convertible to `U`.
template<typename Tp, typename U> concept tuple_for = requires {
  requires tuple<Tp>; requires _::_tuple_for<Tp, U, make_sequence_for<Tp>>::value; };
/// @brief checks if all elements of `Tp` are convertible to `U` without throwing exceptions.
template<typename Tp, typename U> concept nt_tuple_for = requires {
  requires tuple_for<Tp, U>; requires _::_nt_tuple_for<Tp, U, make_sequence_for<Tp>>::value; };

/// @brief value sequence structure.
template<auto... Vs> struct sequence {
private:
  template<typename S> struct _append : _append<to_sequence<S, none>> {};
  template<auto... Ws> struct _append<sequence<Ws...>> : std::type_identity<sequence<Vs..., Ws...>> {};
  template<> struct _append<none> : std::type_identity<none> {};
  template<typename S> struct _extract : _extract<to_sequence<S, none>> {};
  template<nat... Is> struct _extract<sequence<Is...>> : std::type_identity<sequence<value_switch<Is, Vs...>...>> {};
  template<> struct _extract<none> : std::type_identity<none> {};
public:
  /// @brief number of elements.
  static constexpr nat count = sizeof...(Vs);
  /// @brief returns `I`-th value.
  template<nat I> requires(lt(I, count)) static constexpr auto at = value_switch<I, Vs...>;
  /// @brief returns `I`-th type.
  template<nat I> requires(lt(I, count)) using type_at = type_switch<I, decltype(Vs)...>;
  /// @brief appends `Sq`.
  template<sequence_of Sq> using append = typename _append<to_sequence<Sq>>::type;
  /// @brief makes new sequence whose elements are extracted by `Sq`.
  /// @example `sequence<1, 2, 4, 8, 16>::extract<sequence<3, 1, 4>> -> sequence<8, 2, 16>`
  template<sequence_for<sequence> Sq> using extract = typename _extract<to_sequence<Sq, nat>>::type;
  /// @brief returns the first `N` elements.
  template<nat N> requires(N < count) using fore = extract<make_sequence<N>>;
  /// @brief returns the last `N` elements.
  template<nat N> requires(N < count) using back = extract<make_sequence<count, count - N>>;
  /// @brief inserts elements of `Sq` at `I`.
  template<nat I, sequence_of Sq> requires(I < count) using insert =
    typename fore<I>::template append<Sq>::template append<back<count - I>>;
  /// @brief returns `Tm<Vs...>`.
  template<template<auto...> typename Tm> using expand = Tm<Vs...>;
  /// @brief returns `I`-th value.
  template<nat I> requires(I < count) constexpr const auto&& get() const noexcept { return mv(at<I>); }
};

/// @brief type sequence structure.
template<typename... Ts> struct typepack {
private:
  template<typename T, typename U> struct t_append {};
  template<typename... Us, typename... Vs> struct t_append<typepack<Us...>, typepack<Vs...>>
    : std::type_identity<typepack<Us..., Vs...>> {};
  template<typename T, typename S> struct t_extract {};
  template<typename... Us, nat... Is> struct t_extract<typepack<Us...>, sequence<Is...>>
    : std::type_identity<typepack<type_switch<Is, Us...>...>> {};
public:
  /// @brief number of types.
  static constexpr nat count = sizeof...(Ts);
  /// @brief common type of `Ts...`.
  using common = common_type<Ts...>;
  /// @brief returns `I`-th type.
  template<nat I> requires(I < count) using at = type_switch<I, Ts...>;
  /// @brief appends elements of `Tp` to the end.
  template<tuple Tp> using append = typename t_append<typepack, to_typepack<Tp>>::type;
  /// @brief makes new typepack whose elements are extracted by `Sq`.
  template<sequence_for<typepack> Sq> using extract = typename t_extract<typepack, to_sequence<Sq, nat>>::type;
  /// @brief returns the first `N` types.
  template<nat N> requires(N <= count) using fore = extract<make_sequence<N>>;
  /// @brief returns the last `N` types.
  template<nat N> requires(N <= count) using back = extract<make_sequence<count, count - N>>;
  /// @brief inserts elements of `Tp` at `I`.
  template<nat I, tuple T> requires(I < count) using insert =
    typename fore<I>::template append<T>::template append<back<count - I>>;
  /// @brief returns `Tm<Ts...>`.
  template<template<typename...> typename Tm> using expand = Tm<Ts...>;
  /// @brief returns `I`-th type.
  /// @note this can be used in constant-evaluated context.
  template<nat I> requires(I < count) constexpr at<I> get() const noexcept;
};

/// @brief basic tuple structure.
template<typename... Ts> struct list : typepack<Ts...>::template fore<sizeof...(Ts) - 1>::template expand<list> {
  /// @brief base type.
  using base = typepack<Ts...>::template fore<sizeof...(Ts) - 1>::template expand<list>;
  /// @brief number of elements.
  static constexpr nat count = sizeof...(Ts);
  /// @brief last type.
  using last_type = type_switch<count - 1, Ts...>;
  /// @brief last element.
  last_type last;
  /// @brief returns `I`-th element.
  template<nat I> constexpr auto get() & noexcept -> type_switch<I, Ts...>& {
    if constexpr (I == count - 1) return last;
    else return base::template get<I>();
  }
  /// @brief returns `I`-th element.
  template<nat I> constexpr auto get() const& noexcept -> add_const<type_switch<I, Ts...>&> {
    if constexpr (I == count - 1) return last;
    else return base::template get<I>();
  }
  /// @brief returns `I`-th element.
  template<nat I> constexpr auto get() && noexcept -> type_switch<I, Ts...>&& {
    if constexpr (I == count - 1) return fwd<type_switch<I, Ts...>>(last);
    else return mv(*this).base::template get<I>();
  }
  /// @brief returns `I`-th element.
  template<nat I> constexpr auto get() const&& noexcept -> add_const<type_switch<I, Ts...>&&> {
    if constexpr (I == count - 1) return fwd<add_const<type_switch<I, Ts...>>>(last);
    else return mv(*this).base::template get<I>();
  }
};

