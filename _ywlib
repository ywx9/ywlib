                                   requires requires { T(mv(t)), t = fwd<U>(u); } { if (auto a = mv(t); true) return t = fwd<U>(u), static_cast<T&&>(a); };

/// @brief structure for representing a constant.
template<auto V, typename T = decltype(V)>
requires convertible_to<decltype(V), T>
struct constant {
  using type = T;
  static constexpr T value = V;
  constexpr operator T() const noexcept { return V; }
};


