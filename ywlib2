template<included_in<int, long, long long, unsigned, unsigned long, unsigned long long, float, double, long double> T> struct t_stov {
  T operator()(const std::string& Str) const noexcept { return call(Str); }
  T operator()(const std::wstring& Str) const noexcept { return call(Str); }
private:
  static auto call(auto Str) noexcept {
    for (; Str.size(); Str.erase(0, 1)) {
      try {
        if constexpr (same_as<remove_cv<T>, double>) return std::stod(Str);
        else if constexpr (same_as<remove_cv<T>, float>) return std::stof(Str);
        else if constexpr (same_as<remove_cv<T>, long double>) return std::stold(Str);
        else if constexpr (same_as<remove_cv<T>, long long>) return std::stoll(Str);
        else if constexpr (same_as<remove_cv<T>, int>) return std::stoi(Str);
        else if constexpr (same_as<remove_cv<T>, long>) return std::stol(Str);
        else if constexpr (same_as<remove_cv<T>, unsigned long long>) return std::stoull(Str);
        else if constexpr (same_as<remove_cv<T>, unsigned>) return unsigned(std::stoul(Str));
        else if constexpr (same_as<remove_cv<T>, unsigned long>) return std::stoul(Str);
        else return T(std::stoud(Str));
      } catch (const std::exception&) { continue; }
    }
    return T{};
  }
};
template<arithmetic T> inline constexpr t_stov<T> stov;

