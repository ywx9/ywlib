}

// sets/unsets the main window to topmost
inline void topmost(bool TopMost = true, const source& _ = {}) {
  tiff(hwnd, "The window is not initialized", _);
  if (auto style = ::GetWindowLongW(hwnd, GWL_EXSTYLE); TopMost) {
    tiff(::SetWindowPos(hwnd, HWND_TOPMOST, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE), "SetWindowPos failed", _);
    ::SetWindowLongW(hwnd, GWL_EXSTYLE, style | WS_EX_TOPMOST);
  } else {
    tiff(::SetWindowPos(hwnd, HWND_NOTOPMOST, 0, 0, 0, 0, SWP_NOMOVE | SWP_NOSIZE), "SetWindowPos failed", _);
    if (style & WS_EX_TOPMOST) ::SetWindowLongW(hwnd, GWL_EXSTYLE, style & ~WS_EX_TOPMOST);
  }
}

