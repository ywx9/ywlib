class path : public std::filesystem::path {
public:
  using base = std::filesystem::path;
  path() noexcept = default;
  path(const base& p) : base(p) {}
  path(base&& p) noexcept : base(mv(p)) {}
  path(string_type&& s) : base(mv(s)) {}
  template<range Rg> requires character<iter_value<Rg>> path(Rg&& r) : base(yw::begin(r), yw::end(r)) {}
  template<character Ct> path(const Ct* s) : base(s) {}
  static bool exists(const auto& p) ywlib_wrapper(std::filesystem::exists(p));
  static bool remove(const auto& p) ywlib_wrapper(std::filesystem::remove(p));
  static bool is_file(const auto& p) ywlib_wrapper(std::filesystem::is_regular_file(p));
  static bool is_directory(const auto& p) ywlib_wrapper(std::filesystem::is_directory(p));
  static nat file_size(const auto& p) ywlib_wrapper(std::filesystem::file_size(p));
  static array<path> list(const convertible_to<base> auto& p, bool Recursive = false);
  static void read(const convertible_to<base> auto& p, cnt_range auto&& Out) requires (!is_const<decltype(yw::data(Out))>);
  static array<nat1> read(const convertible_to<base> auto& p) { array<nat1> a(file_size(p), nat1{}); read(p, a); return a; }
  static void write(const convertible_to<base> auto& p, cnt_range auto&& In);
  bool exists() const { return exists(*this); }
  bool remove() const { return remove(*this); }
  bool is_file() const { return is_file(*this); }
  bool is_directory() const { return is_directory(*this); }
  nat file_size() const { return file_size(*this); }
  std::vector<path> list(bool Recursive = false) const { return list(*this, Recursive); }
  void read(cnt_range auto&& Out) const requires(!is_const<decltype(yw::data(Out))>) { return read(*this, Out); }
  array<nat1> read() const { return read(*this); }
  void write(cnt_range auto&& In) const { return write(*this, In); }
};

array<path> path::list(const convertible_to<base> auto& p, bool Recursive) {
  array<path> a;
  if (!std::filesystem::exists(p)) throw std::runtime_error(std::format("runtime error in path::list : the path does not exist ({})", base(p)));
  if (!std::filesystem::is_directory(p)) throw std::runtime_error(std::format("runtime error in path::list : the path is not a directory ({})", base(p)));
  if (Recursive) for (const auto& e : std::filesystem::recursive_directory_iterator(p)) a.push_back(e.path());
  else for (const auto& e : std::filesystem::directory_iterator(p)) a.push_back(e.path());
  return a;
}

void path::read(const convertible_to<base> auto& p, cnt_range auto&& Out) requires (!is_const<decltype(yw::data(Out))>) {
  if (const auto n = yw::size(Out) * sizeof(iter_value<decltype(Out)>); p.file_size() == n) {
    if (std::ifstream ifs(p, std::ios::binary); ifs) return void(ifs.read(reinterpret_cast<char*>(yw::data(Out)), n));
    else throw std::runtime_error(std::format("runtime error in path::read : failed to open the file ({})", p.string()));
  } else throw std::runtime_error(std::format("runtime error in path::read : the byte size of the output range is not equal to the file size ({})", p.string()));
}

void path::write(const convertible_to<base> auto& p, cnt_range auto&& In) {
  if (std::ofstream ofs(p, std::ios::binary); ofs) {
    if (const auto n = yw::size(In) * sizeof(iter_value<decltype(In)>); ofs.write(reinterpret_cast<const char*>(yw::data(In)), n)) return;
    else throw std::runtime_error(std::format("runtime error in path::write : failed to write to the file ({})", p.string()));
  } else throw std::runtime_error(std::format("runtime error in path::write : failed to open the file ({})", p.string()));
}
}

