template<typename T> struct t_type { using type = T; };              ///< holds a member type `type` that represents `T`.
template<typename T> using type = typename t_type<T>::type;          ///< indirectly represents `T`.
template<typename T> concept valid = requires { typename type<T>; }; ///< checks if `T` is a valid type.

/// @brief checks if all of `Ts...` are the same as `T`.
template<typename T, typename... Ts> concept same_as = (std::same_as<T, Ts> && ...);
/// @brief checks if any of `Ts...` are the same as `T`.
template<typename T, typename... Ts> concept included_in = (std::same_as<T, Ts> || ...);
/// @brief checks if `T` is derived from all of `Ts...`.
template<typename T, typename... Ts> concept derived_from = (std::derived_from<T, Ts> && ...);
/// @brief checks if `T` is explicitly convertible to all of `Ts...`.
template<typename T, typename... Ts> concept castable_to = requires(T (&f)()) { ((static_cast<Ts>(f())), ...); };
/// @brief checks if `T` is explicitly convertible to all of `Ts...` without throwing exceptions.
template<typename T, typename... Ts> concept nt_castable_to =
  castable_to<T, Ts...> && requires(T (&f)() noexcept) { ((static_cast<Ts>(f())), ...); };
/// @brief checks if `T` is implicitly convertible to all of `Ts...`.
template<typename T, typename... Ts> concept convertible_to = castable_to<T, Ts...> && (std::convertible_to<T, Ts> && ...);
/// @brief checks if `T` is implicitly convertible to all of `Ts...` without throwing exceptions.
template<typename T, typename... Ts> concept nt_convertible_to = nt_castable_to<T, Ts...> && (std::convertible_to<T, Ts> && ...);
/// @brief checks if `T` is numerical value type.
template<typename T> concept numerical = nt_convertible_to<T, int4, int8, nat4, nat8, fat4, fat8>;

/// @brief represents a constant value.
template<auto V, typename T = decltype(V)> requires convertible_to<decltype(V), T> struct constant {
  /// @brief constant value.
  static constexpr T value = V;
  /// @brief conversion to value.
  consteval operator T() const noexcept { return value; }
  /// @brief function call operator.
  consteval T operator()() const noexcept { return value; }
};

/// @brief represents a null-value.
/// @details Correspondence with the standard library:
/// - `std::common_type<none, T> -> none`.
/// - `Ostream << none{} -> "none"`.
/// - `std::format("{}", none{}) -> "none"`.
struct none {
  /// @brief default constructor.
  constexpr none() noexcept = default;
  /// @brief constructor. `none` can be constructed from any arguments.
  constexpr none(auto&&...) noexcept {}
  /// @brief assignment operator. `none` can be assigned from any type.
  constexpr none& operator=(auto&&) noexcept { return *this; }
  /// @brief explicit conversion to bool. `none` always returns `false`.
  explicit constexpr operator bool() const noexcept { return false; }
  /// @brief function call operator. `none` can be called with any arguments.
  constexpr none operator()(auto&&...) const noexcept { return {}; }
  /// @brief equality operator. `none` can be compared with any type and always returns `false`.
  [[nodiscard]] constexpr friend bool operator==(none, none) noexcept { return false; }
  /// @brief three-way comparison operator. `none` can be compared with any type and always returns `unordered`.
  [[nodiscard]] constexpr friend auto operator<=>(none, none) noexcept { return unordered; }
  /// @brief unary plus operator.
  [[nodiscard]] constexpr friend none operator+(none) noexcept { return {}; }
  /// @brief unary minus operator.
  [[nodiscard]] constexpr friend none operator-(none) noexcept { return {}; }
  /// @brief addition operator. `none` can be added with any type and always returns `none`.
  [[nodiscard]] constexpr friend none operator+(none, none) noexcept { return {}; }
  /// @brief subtraction operator. `none` can be subtracted from any type and always returns `none`.
  [[nodiscard]] constexpr friend none operator-(none, none) noexcept { return {}; }
  /// @brief multiplication operator. `none` can be multiplied with any type and always returns `none`.
  [[nodiscard]] constexpr friend none operator*(none, none) noexcept { return {}; }
  /// @brief division operator. `none` can be divided by any type and always returns `none`.
  [[nodiscard]] constexpr friend none operator/(none, none) noexcept { return {}; }
  /// @brief addition assignment operator. `none` can be added with any type and does nothing.
  constexpr none& operator+=(none) noexcept { return *this; }
  /// @brief subtraction assignment operator. `none` can be subtracted from any type and does nothing.
  constexpr none& operator-=(none) noexcept { return *this; }
  /// @brief multiplication assignment operator. `none` can be multiplied with any type and does nothing.
  constexpr none& operator*=(none) noexcept { return *this; }
  /// @brief division assignment operator. `none` can be divided by any type and does nothing.
  constexpr none& operator/=(none) noexcept { return *this; }
};

/// @brief represents a value as a double-precision floating-point number.
/// @details Correspondence with the standard library:
/// - `std::common_type<value, common_with<fat8>> -> fat8`.
/// - `std::format("{}", value) -> (std::format("{}", fat8))`.
struct value {
  /// @brief value.
  fat8 _{};
  /// @brief default constructor.
  constexpr value() noexcept = default;
  /// @brief constructor with `none`. This constructs a NaN value.
  constexpr value(none) noexcept : _(std::numeric_limits<fat8>::quiet_NaN()) {}
  /// @brief constructor with a value.
  template<numerical T> requires(!same_as<T, value>) constexpr value(T&& Value) noexcept : _(fat8(static_cast<T&&>(Value))) {}
  /// @brief conversion to `fat8`.
  constexpr operator fat8&() & noexcept { return _; }
  /// @brief conversion to `fat8`.
  constexpr operator const fat8&() const& noexcept { return _; }
  /// @brief conversion to `fat8`.
  constexpr operator fat8&&() && noexcept { return static_cast<fat8&&>(_); }
  /// @brief conversion to `fat8`.
  constexpr operator const fat8&&() const&& noexcept { return static_cast<const fat8&&>(_); }
  /// @brief explicit conversion.
  template<typename T> requires castable_to<fat8, T> explicit constexpr operator T() const noexcept(nt_castable_to<fat8, T>) { return T(_); }
  /// @brief addition assignment.
  template<numerical T> constexpr value& operator+=(T&& Value) noexcept { return _ += double(static_cast<T&&>(Value)), *this; }
  /// @brief subtraction assignment.
  template<numerical T> constexpr value& operator-=(T&& Value) noexcept { return _ -= double(static_cast<T&&>(Value)), *this; }
  /// @brief multiplication assignment.
  template<numerical T> constexpr value& operator*=(T&& Value) noexcept { return _ *= double(static_cast<T&&>(Value)), *this; }
  /// @brief division assignment.
  template<numerical T> constexpr value& operator/=(T&& Value) noexcept { return _ /= double(static_cast<T&&>(Value)), *this; }
};

