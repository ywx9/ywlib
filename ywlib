  template<nat... Is> struct _extract<sequence<Is...>> : std::type_identity<sequence<value_switch<Is, Vs...>...>> {};
  template<> struct _extract<none> : std::type_identity<none> {};
public:
  /// @brief number of elements.
  static constexpr nat count = sizeof...(Vs);
  /// @brief returns `I`-th value.
  template<nat I> requires(lt(I, count)) static constexpr auto at = value_switch<I, Vs...>;
  /// @brief returns `I`-th type.
  template<nat I> requires(lt(I, count)) using type_at = type_switch<I, decltype(Vs)...>;
  /// @brief appends `Sq`.
  template<sequence_of Sq> using append = typename _append<to_sequence<Sq>>::type;
  /// @brief makes new sequence whose elements are extracted by `Sq`.
  /// @note `sequence<1, 2, 4, 8, 16>::extract<sequence<3, 1, 4>> -> sequence<8, 2, 16>`
  template<sequence_for<sequence> Sq> using extract = typename _extract<to_sequence<Sq, nat>>::type;
  /// @brief returns the first `N` elements.
  template<nat N> requires(N < count) using fore = extract<make_sequence<N>>;
  /// @brief returns the last `N` elements.
  template<nat N> requires(N < count) using back = extract<make_sequence<count, count - N>>;
  /// @brief inserts elements of `Sq` at `I`.
  template<nat I, sequence_of Sq> requires(I < count) using insert = typename fore<I>::template append<Sq>::template append<back<count - I>>;
  /// @brief returns `Tm<Vs...>`.
  template<template<auto...> typename Tm> using expand = Tm<Vs...>;
  /// @brief returns `I`-th value.
  template<nat I> requires(I < count) constexpr const auto&& get() const noexcept { return mv(at<I>); }
};

