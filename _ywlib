inline constexpr auto mv = []<typename T>(T&& t) noexcept -> decltype(auto) { return static_cast<add_rvref<T>>(t); };
template<typename T> inline constexpr auto fwd = [](auto&& t) noexcept -> T&& { return static_cast<T&&>(t); };
