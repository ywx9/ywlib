  friend constexpr rect& operator-=(rect& A, const int& B) noexcept { return A = A - B; }
  friend constexpr rect& operator*=(rect& A, const int& B) noexcept { return A = A * B; }
  friend constexpr rect& operator/=(rect& A, const int& B) noexcept { return A = A / B; }
