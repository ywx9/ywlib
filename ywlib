/// @brief checks if `F` is invocable with `As...`.
template<typename F, typename... As> concept invocable = std::invocable<F, As...>;
/// @brief checks if `F` is invocable with `As...` without throwing exceptions.
template<typename F, typename... As> concept nt_invocable = invocable<F, As...> && requires { requires std::is_nothrow_invocable_v<F, As...>; };

/// @brief performs `std::invoke(Func, Args...)`.
/// @return `none` if the result of `std::invoke(Func, Args...)` is `void`; otherwise, returns as it.
inline constexpr auto invoke = []<typename F, typename... As>(F&& Func, As&&... Args) noexcept(nt_invocable<F, As...>)
  -> decltype(auto) requires invocable<F, As...> {
  if constexpr (is_void<std::invoke_result<F, As...>>) return std::invoke(fwd<F>(Func), fwd<As>(Args)...), none{};
  else return std::invoke(fwd<F>(Func), fwd<As>(Args)...); };

/// @brief returns the result type of `invoke(F, As...)`.
template<typename F, typename... As> using invoke_result = decltype(invoke(declval<F>(), declval<As>()...));

/// @brief checks if `F` is invocable with `As...` and the result is convertible to `R`.
template<typename F, typename R, typename... As> concept invocable_r =
  invocable<F, As...> && convertible_to<invoke_result<F, As...>, R>;

/// @brief checks if `F` is invocable with `As...` and the result is convertible to `R` without throwing exceptions.
template<typename F, typename R, typename... As> concept nt_invocable_r =
  nt_invocable<F, As...> && nt_convertible_to<invoke_result<F, As...>, R>;

/// @brief checks if `F` is a predicate with `As...`.
template<typename F, typename... As> concept predicate = invocable_r<F, bool, As...>;

/// @brief invokes `F` with `As...` and returns the result as `R`.
template<typename R> inline constexpr auto invoke_r =
  []<typename F, typename... As>(F&& f, As&&... as) noexcept(nt_invocable_r<F, R, As...>) -> R
  requires invocable_r<F, R, As...> { return static_cast<R>(invoke(fwd<F>(f), fwd<As>(as)...)); };

