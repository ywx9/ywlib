/// @brief resizes the main window
inline void resize(const auto Width, const auto Height, const source& _ = {}) {
  tiff(Width > 0 && Height > 0, "Invalid window size", _);
  tiff(hwnd && system::swapchain && d2d_context, "The window is not initialized", _);
  system::rendertarget.reset(), width = int(Width), height = int(Height);
  tiff(::SetWindowPos(hwnd, 0, 0, 0, width + system::padding_width, height + system::padding_height, SWP_NOMOVE | SWP_NOZORDER), "SetWindowPos failed", _);
  tiff(system::swapchain->ResizeBuffers(2, UINT(width), UINT(height), DXGI_FORMAT_UNKNOWN, 0), _);
  comptr<ID3D11Texture2D> tex;
  tiff(system::swapchain->GetBuffer(0, IID_PPV_ARGS(tex.init())), _);
  comptr<IDXGISurface> surface;
  tiff(tex->QueryInterface(IID_PPV_ARGS(surface.init())), _);
  auto props = D2D1::BitmapProperties1(D2D1_BITMAP_OPTIONS_TARGET | D2D1_BITMAP_OPTIONS_CANNOT_DRAW,
                                       D2D1::PixelFormat(DXGI_FORMAT_UNKNOWN, D2D1_ALPHA_MODE_PREMULTIPLIED));
  tiff(d2d_context->CreateBitmapFromDxgiSurface(surface, props, system::rendertarget.init()), _);
}

