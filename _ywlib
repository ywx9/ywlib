inline void bitmap_to_png(convertible_to<ID2D1Bitmap*> auto&& b, const std::filesystem::path& p, const source& _ = {}) {
  comptr<IWICStream> stream{};
  tiff(wic_factory->CreateStream(stream.init()), _);
  tiff(stream->InitializeFromFilename(p.c_str(), GENERIC_WRITE), _);
  comptr<IWICBitmapEncoder> encoder{};
  tiff(wic_factory->CreateEncoder(GUID_ContainerFormatPng, nullptr, encoder.init()), _);
  tiff(encoder->Initialize(stream, WICBitmapEncoderNoCache), _);
  comptr<IWICBitmapFrameEncode> frame{};
  tiff(encoder->CreateNewFrame(frame.init(), nullptr), _);
  tiff(frame->Initialize(nullptr), _);
  comptr<IWICImageEncoder> image_encoder{};
  tiff(wic_factory->CreateImageEncoder(d2d_device, image_encoder.init()), _);
  tiff(image_encoder->WriteFrame(b, frame, nullptr), _);
  tiff(frame->Commit(), _);
  tiff(encoder->Commit(), _);
  tiff(stream->Commit(STGC_DEFAULT), _);
}
