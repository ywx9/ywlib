template<nat N, nat Zero = 0> requires (0 < N && N <= 4 && Zero < 16) struct t_xvdot {
  xvector operator()(const xvector& A, const xvector& B) const noexcept {
    if constexpr (Zero == 15) return Xv(xv_zero);
    else if constexpr (N == 1) {
      if constexpr (bitcount(Zero) == 3) return xvinsert<inspects<!(Zero & 1), !(Zero & 2), !(Zero & 4), !(Zero & 8)>, 0, Zero>(A, xvmul(A, B));
      else if constexpr (Zero == 0) return xvpermute<0, 0, 0, 0>(xvmul(A, B));
      else return xvpermute<Zero & 1 ? 0 : 0, Zero & 2 ? 1 : 0, Zero & 4 ? 2 : 0, Zero & 8 ? 3 : 0>(xv_zero, xvmul(A, B));
    } else if constexpr (N == 2) {

    }
    if constexpr (N == 1 && bitcount(Zero) == 3)
    else if constexpr (N == 2)
    else return _mm_dp_ps(A, B, select_value<N, 0, 16, 48, 112, 240> | (15 ^ Zero));
  }
  xwector operator()(const xwector& A, const xwector& B) const noexcept { return xvdot<N, Zero>(A, B); }
  xrect operator()(const xrect& A, const xrect& B) const noexcept { return xvdot<N, Zero>(A, B); }
};

template<nat N, nat Zero = 0b0000> requires (0 < N && N <= 4 && Zero < 16)
inline constexpr auto xvdot = []<xv Xv>(const Xv& A, const Xv& B) noexcept {
  if constexpr (Zero == 15) return Xv(xv_zero);
  else if constexpr (same_as<Xv, xvector>) {
    if constexpr (N == 1 && bitcount(Zero) == 3) return xvinsert<inspects<!(Zero & 1), !(Zero & 2), !(Zero & 4), !(Zero & 8)>, 0, Zero>(A, xvmul(A, B));
    else return _mm_dp_ps(A, B, select_value<N, 0, 16, 48, 112, 240> | (15 ^ Zero));
  } else if constexpr (same_as<Xv, xwector>) { // can improve performance
    xwector a;
    if constexpr (N == 1) a = xvmul(A, B);
    else if constexpr (N == 2) a = _mm256_hadd_pd(xvmul(A, B), A);
    else if constexpr (N == 3) (a = xvmul(A, B)), a = xvadd(_mm256_hadd_pd(a, A), _mm256_castpd128_pd256(_mm256_extractf128_pd(a, 1)));
    else if constexpr (N == 4) (a = _mm256_hadd_pd(xvmul(A, B), A)), a = xvadd(a, _mm256_castpd128_pd256(_mm256_extractf128_pd(a, 1)));
    return xvsetzero<Zero & 1, Zero & 2, Zero & 4, Zero & 8>(xvpermute<0, 0, 0, 0>(a));
  } else if constexpr (same_as<Xv, xrect>) { // can improve performance
    xrect a;
    if constexpr (N == 1) a = xvmul(A, B);
    else if constexpr (N == 2) a = _mm_hadd_epi32(xvmul(A, B), A);
    else if constexpr (N == 3) (a = xvmul(A, B)), a = xvadd(_mm_hadd_epi32(a, A), xvpermute<2, -1, -1, -1>(a));
    else if constexpr (N == 4) (a = _mm_hadd_epi32(xvmul(A, B), A)), a = xvadd(a, xvpermute<2, -1, -1, -1>(a));
    return xvsetzero<Zero & 1, Zero & 2, Zero & 4, Zero & 8>(xvpermute<0, 0, 0, 0>(a)); } };

template<nat N> requires (0 < N && N <= 4) inline constexpr auto xvtransform =
  []<xm Xm, xv Xv>(const Xm& M, const Xv& V) noexcept {
  Xv o = xvdot<N, 0b1110>(get<0>(M), V);
  if constexpr (N >= 2) o = xvinsert<1, 0, (N == 1) * 0b1100>(o, xvdot<N, 0b1110>(get<1>(M), V));
  if constexpr (N >= 3) o = xvinsert<2, 0, (N == 2) * 0b1000>(o, xvdot<N, 0b1110>(get<2>(M), V));
  if constexpr (N == 4) o = xvinsert<3, 0, 0>(o, xvdot<N, 0b1110>(get<3>(M), V));
  return o;};

inline constexpr auto xmproduct =
  []<xm XmL, xm XmR>(const XmL& L, const XmR& R, XmL& O) noexcept
  requires (same_as<remove_cvref<element_t<XmL, 0>>, remove_cvref<element_t<XmR, 0>>> && le(extent<XmR>, 4)) {
  constexpr auto f = [](const auto& A, const auto& B, auto& C) noexcept {
    C = xvmul(xvpermute<0, 0, 0, 0>(A), get<0>(B));
    if constexpr (extent<XmR> >= 2) C = xvfma(xvpermute<1, 1, 1, 1>(A), get<1>(B), C);
    if constexpr (extent<XmR> >= 3) C = xvfma(xvpermute<2, 2, 2, 2>(A), get<2>(B), C);
    if constexpr (extent<XmR> == 4) C = xvfma(xvpermute<3, 3, 3, 3>(A), get<3>(B), C); };
  [&]<nat... Is>(sequence<Is...>) noexcept { (f(get<Is>(L), R, get<Is>(O)), ...); }(make_indices_for<XmL>{}); };

