template<castable_to<nat> auto I> inline constexpr auto parameter_switch =
  []<typename A, typename... As>(A&& Arg, As&&... Args) noexcept
  -> decltype(auto) requires ((is_bool<decltype(I)> && sizeof...(Args) == 1) ||
                              (!is_bool<decltype(I)> && static_cast<nat>(I) <= sizeof...(Args))) {
  if constexpr (is_bool<decltype(I)>) return parameter_switch<nat(!I)>(fwd<A>(Arg), fwd<Args>(Args)...);
  else if constexpr (same_as<decltype(I), nat>) {
    if constexpr (I == 0) return fwd<A>(Arg);
    else return parameter_switch<I - 1>(fwd<Args>(Args)...);
  } else return parameter_switch<nat(I)>(fwd<A>(Arg), fwd<Args>(Args)...); };

