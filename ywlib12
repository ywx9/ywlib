/// @brief manages mouse events.
struct yw::mouse {
  inline static const auto& x = main::system::Window::mouse.left; // x-position of the mouse
  inline static const auto& y = main::system::Window::mouse.top;  // y-position of the mouse
  inline static const auto& left = key::lbutton;                  // left mouse button
  inline static const auto& right = key::rbutton;                 // right mouse button
  inline static const auto& middle = key::mbutton;                // middle mouse button
  inline static const auto& extra1 = key::xbutton1;               // extra mouse button 1
  inline static const auto& extra2 = key::xbutton2;               // extra mouse button 2
  inline static const auto& hover = main::system::Window::hover;  // true if the mouse is hovering over the window
  inline static void (*wheeled)(int delta) = nullptr;             // callback function for mouse wheel
  inline static void (*moved)(int dx, int dy) = nullptr;          // callback function for mouse movement
  /// @brief sets the new position of the mouse
  mouse(const numerical auto X, const numerical auto Y) noexcept { ::SetCursorPos(int(X), int(Y)); }
};

LRESULT CALLBACK yw::main::system::Window::wndproc(HWND hw, UINT msg, WPARAM wp, LPARAM lp) {
  static TRACKMOUSEEVENT tme{sizeof(TRACKMOUSEEVENT), TME_LEAVE};
  switch (msg) {
  case WM_MOUSEMOVE:
    if (!hover) ::TrackMouseEvent(&tme), hover = true;
    auto mm = _mm_cvtepi16_epi32(_mm_loadu_si128(reinterpret_cast<const __m128i*>(&lp)));
    auto nn = _mm_sub_epi32(mm, _mm_loadu_si128(reinterpret_cast<const __m128i*>(&mouse)));
    mm = _mm_castps_si128(_mm_shuffle_ps(_mm_castsi128_ps(mm), _mm_castsi128_ps(nn), 0b01000100));
    _mm_storeu_si128(reinterpret_cast<__m128i*>(&mouse), mm);
  }
  return ::DefWindowProcW(hw, msg, wp, lp);
}
