namespace main::system {

inline stopwatch timer{};
inline int mouse_wheel_delta{};
inline int width{200}, height{200};
inline int padding_left{}, padding_top{}, padding_width{}, padding_height{};
inline std::vector<std::filesystem::path> dropped_files{};

/// @brief window procedure
LRESULT WINAPI wndproc(HWND hw, UINT msg, WPARAM wp, LPARAM lp) {
  switch (msg) {
  case WM_MOUSEWHEEL:
    mouse_wheel_delta += GET_WHEEL_DELTA_WPARAM(wp) / WHEEL_DELTA;
    return 0;
  case WM_DROPFILES:
    dropped_files.resize(::DragQueryFileW((HDROP)wp, 0xFFFFFFFF, nullptr, 0));
    for (UINT i{}; i < dropped_files.size(); ++i) {
      auto temp = std::wstring(::DragQueryFileW((HDROP)wp, i, nullptr, 0), L'\0');
      ::DragQueryFileW((HDROP)wp, i, temp.data(), UINT(temp.size() + 1));
      dropped_files[i] = std::move(temp);
    }
  case WM_CLOSE:
    DestroyWindow(hw);
    return 0;
  case WM_DESTROY:
    PostQuitMessage(0);
    return 0;
  default:
    return DefWindowProcW(hw, msg, wp, lp);
  }
}

/// @brief instance handle
inline const HINSTANCE hinstance = [] { return GetModuleHandle(nullptr); }();

/// @brief handle of the main window
inline const HWND hwnd = [] {
  try {
    tiff(hinstance, "GetModuleHandle failed");
#ifdef ywlib_window_name
    static constexpr const wchar_t* name = ywlib_window_name;
#else
    static constexpr const wchar_t* name = L"ywlib";
#endif
    WNDCLASSEXW wc{sizeof(WNDCLASSEXW), CS_OWNDC, wndproc, 0, 0, hinstance};
    wc.hCursor = ::LoadCursorW(nullptr, IDC_ARROW), wc.lpszClassName = name;
#ifdef ywlib_window_class_style
    wc.style = ywlib_window_class_style;
#else
    wc.style = CS_OWNDC;
#endif
    tiff(::RegisterClassExW(&wc), "RegisterClassEx failed");
#ifdef ywlib_window_width_height
    width = parameter_switch<0>(ywlib_window_width_height), height = parameter_switch<1>(ywlib_window_width_height);
#endif
#ifdef ywlib_window_left_top
    static constexpr int pos[2] = {ywlib_window_left_top};
#else
    static constexpr int pos[2] = {0, 0};
#endif
    auto hw = ::CreateWindowExW(
#ifdef ywlib_window_ex_style
      ywlib_window_ex_style | WS_EX_ACCEPTFILES,
#else
      WS_EX_ACCEPTFILES,
#endif
      name, name,
#ifdef ywlib_window_style
      ywlib_window_style,
#else
      WS_OVERLAPPED | WS_SYSMENU | WS_CLIPCHILDREN,
#endif
      pos[0], pos[1], width, height, nullptr, nullptr, hinstance, nullptr);
    tiff(hw, "CreateWindowEx failed");
    [&](RECT r) { ::GetClientRect(hw, &r), padding_width = width - r.right, padding_height = height - r.bottom; }({});
    padding_left = padding_width / 2, padding_top = padding_height - padding_left;
    ::SetWindowPos(hw, HWND_TOP, pos[0] -padding_left, pos[1], width + padding_width, height + padding_height, SWP_SHOWWINDOW);
    ::ShowWindow(hw, SW_SHOW), ::SetForegroundWindow(hw), ::SetFocus(hw);
    return hw;
  } catch (...) { return HWND{}; } }();

/// @brief flgs for COM initialization
inline const bool com_initialized = [] {
  try {
    tiff(::CoInitializeEx(nullptr, COINIT_APARTMENTTHREADED));
    return true;
  } catch (...) { return false; } }();

/// @brief Direct3D 11 device
inline comptr<ID3D11Device1> d3d_device{};

/// @brief Direct3D 11 device context
inline comptr<ID3D11DeviceContext1> d3d_context = [] {
  if (!com_initialized) return comptr<ID3D11DeviceContext1>{};
  try {
#ifdef ywlib_d3d_feature_level
  static constexpr D3D_FEATURE_LEVEL levels[] = {ywlib_d3d_feature_level};
#else
  static constexpr D3D_FEATURE_LEVEL levels[] = {D3D_FEATURE_LEVEL_11_1, D3D_FEATURE_LEVEL_11_0};
#endif
  comptr<ID3D11DeviceContext1> temp;
  tiff(::D3D11CreateDevice(nullptr, D3D_DRIVER_TYPE_HARDWARE, nullptr, D3D11_CREATE_DEVICE_BGRA_SUPPORT,
                           levels, sizeof(levels) / sizeof(D3D_FEATURE_LEVEL), D3D11_SDK_VERSION,
                           (ID3D11Device**)d3d_device.init(), nullptr, (ID3D11DeviceContext**)temp.init()));
  return std::move(temp);
  } catch(...) { return d3d_device.reset(), comptr<ID3D11DeviceContext1>{}; } }();

/// @brief DirectXGI factory
inline comptr<IDXGIFactory2> dxgi_factory = [] {
  if (!com_initialized) return comptr<IDXGIFactory2>{};
  try {
  comptr<IDXGIFactory2> temp;
  tiff(::CreateDXGIFactory2(0, IID_PPV_ARGS(temp.init())));
  if (hwnd) tiff(temp->MakeWindowAssociation(hwnd, DXGI_MWA_NO_ALT_ENTER));
  return std::move(temp);
  } catch(...) { return comptr<IDXGIFactory2>{}; } }();

/// @brief DirectXGI device
inline comptr<IDXGIDevice1> dxgi_device = [] {
  if (!d3d_device) return comptr<IDXGIDevice1>{};
  try {
  comptr<IDXGIDevice1> temp;
  tiff(d3d_device->QueryInterface(IID_PPV_ARGS(temp.init())));
  return std::move(temp);
  } catch(...) { return comptr<IDXGIDevice1>{}; } }();

/// @brief DirectXGI swap chain
inline comptr<IDXGISwapChain1> swapchain = [] {
  if (!(hwnd && d3d_device && dxgi_factory)) return comptr<IDXGISwapChain1>{};
  try {
  comptr<IDXGISwapChain1> temp;
  DXGI_SWAP_CHAIN_DESC1 desc{};
  desc.Width = UINT(width), desc.Height = UINT(height);
  desc.Format = DXGI_FORMAT_R8G8B8A8_UNORM;
  desc.SampleDesc.Count = 1;
  desc.BufferUsage = DXGI_USAGE_RENDER_TARGET_OUTPUT;
  desc.BufferCount = 2;
  desc.Scaling = DXGI_SCALING_STRETCH;
  desc.SwapEffect = DXGI_SWAP_EFFECT_FLIP_DISCARD;
  tiff(dxgi_factory->CreateSwapChainForHwnd(d3d_device, hwnd, &desc, nullptr, nullptr, temp.init()));
  return std::move(temp);
  } catch(...) { return comptr<IDXGISwapChain1>{}; } }();

/// @brief Direct2D factory
inline comptr<ID2D1Factory1> d2d_factory = [] {
  if (!com_initialized) return comptr<ID2D1Factory1>{};
  try {
    comptr<ID2D1Factory1> temp;
    tiff(::D2D1CreateFactory(D2D1_FACTORY_TYPE_SINGLE_THREADED, temp.init()));
    return std::move(temp);
