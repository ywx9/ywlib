/// @brief performs `std::invoke(Func, Args...)`.
/// @return `none` if the result of `std::invoke(Func, Args...)` is `void`; otherwise, returns as it.
inline constexpr auto invoke = []<typename F, typename... As>(F&& Func, As&&... Args) noexcept(nt_invocable<F, As...>)
  -> decltype(auto) requires invocable<F, As...> {
  if constexpr (is_void<std::invoke_result<F, As...>>) return std::invoke(fwd<F>(Func), fwd<As>(Args)...), none{};
  else return std::invoke(fwd<F>(Func), fwd<As>(Args)...); };

