  /// Convert a utf-8 string to utf-32 string.
  constexpr string<uct4> operator()(const string_view<uct1>& utf8) const {
    string<uct4> utf32(utf8.size(), 0);
    nat size = 0;
    for (auto i = utf8.begin(); i < utf8.end(); ++i) {
      if (*i < 0x80) utf32[size++] = *i;
      else if (*i < 0xE0) utf32[size++] = (*i & 0x1F) << 6 | (*(++i) & 0x3F);
      else if (*i < 0xF0) utf32[size++] = (*i & 0x0F) << 12 | (*(++i) & 0x3F) << 6 | (*(++i) & 0x3F);
