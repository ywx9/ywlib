template<typename T> concept is_const = std::is_const_v<T>;                           ///< checks if `T` has `const` qualifier.
template<typename T> concept is_volatile = std::is_volatile_v<T>;                     ///< checks if `T` has `volatile` qualifier.
template<typename T> concept is_cv = is_const<T> && is_volatile<T>;                   ///< checks if `T` has both cv-qualifiers.
template<typename T> concept is_lvref = std::is_lvalue_reference_v<T>;                ///< checks if `T` is a lvalue reference.
template<typename T> concept is_rvref = std::is_rvalue_reference_v<T>;                ///< checks if `T` is a rvalue reference.
template<typename T> concept is_reference = is_lvref<T> || is_rvref<T>;               ///< checks if `T` is a reference.
template<typename T> concept is_pointer = std::is_pointer_v<T>;                       ///< checks if `T` is a pointer.
template<typename T> concept is_bounded_array = std::is_bounded_array_v<T>;           ///< checks if `T` is a bounded array.
template<typename T> concept is_unbounded_array = std::is_unbounded_array_v<T>;       ///< checks if `T` is an unbounded array.
template<typename T> concept is_array = is_bounded_array<T> || is_unbounded_array<T>; ///< checks if `T` is an array.
template<typename T> concept is_function = std::is_function_v<T>;                     ///< checks if `T` is a function.

namespace _ {
template<typename T, typename U = std::remove_cv_t<T>> struct _remove_all_pointers : t_type<T> {};
template<typename T, typename U> struct _remove_all_pointers<T, U*> : _remove_all_pointers<U> {};
}
template<typename T> using remove_cv = std::remove_cv_t<T>;                                 ///< removes cv-qualifiers from `T`.
template<typename T> using remove_const = std::remove_const_t<T>;                           ///< removes `const` qualifier from `T`.
template<typename T> using remove_volatile = std::remove_volatile_t<T>;                     ///< removes `volatile` qualifier from `T`.
template<typename T> using remove_ref = std::remove_reference_t<T>;                         ///< removes reference from `T`.
template<typename T> using remove_cvref = std::remove_cvref_t<T>;                           ///< removes reference and cv-qualifiers from `T`.
template<typename T> using remove_extent = std::remove_extent_t<T>;                         ///< removes extent from `T`.
template<typename T> using remove_all_extents = std::remove_all_extents_t<T>;               ///< removes all extents from `T`.
template<typename T> using remove_pointer = std::remove_pointer_t<T>;                       ///< removes pointer from `T`.
template<typename T> using remove_all_pointers = typename _::_remove_all_pointers<T>::type; ///< removes all pointers from `T`.

namespace _ {
template<typename T, typename U = remove_cv<T>> struct _member_type;
template<typename T, typename M, typename C> struct _member_type<T, M C::*> { using m = M; using c = C; };
}
template<typename T> concept is_memptr = is_pointer<T> && std::is_member_pointer_v<T>;                  ///< checks if `T` is a member pointer.
template<is_memptr Mp> using member_type = typename _::_member_type<Mp>::m;                             ///< member type of a member pointer.
template<is_memptr Mp> using class_type = typename _::_member_type<Mp>::c;                              ///< class type of a member pointer.
template<typename T> concept is_member_function_pointer = is_memptr<T> && is_function<member_type<T>>;  ///< checks if `T` is a member function pointer.
template<typename T> concept is_member_object_pointer = is_memptr<T> && !is_member_function_pointer<T>; ///< checks if `T` is a member object pointer.

template<typename T> concept is_enum = std::is_enum_v<T>;                                              ///< checks if `T` is an enumeration.
template<typename T> concept is_class = std::is_class_v<T>;                                            ///< checks if `T` is a class.
template<typename T> concept is_union = std::is_union_v<T>;                                            ///< checks if `T` is a union.
template<typename T> concept is_abstract = is_class<T> && std::is_abstract_v<T>;                       ///< checks if `T` is an abstract class.
template<typename T> concept is_aggregate = is_class<T> && std::is_aggregate_v<T>;                     ///< checks if `T` is an aggregate.
template<typename T> concept is_empty = is_class<T> && std::is_empty_v<T>;                             ///< checks if `T` is a trivially copyable class.
template<typename T> concept is_final = is_class<T> && std::is_final_v<T>;                             ///< checks if `T` is a final class.
template<typename T> concept is_polymorphic = is_class<T> && std::is_polymorphic_v<T>;                 ///< checks if `T` is a polymorphic class.
template<typename T> concept has_virtual_destructor = is_class<T> && std::has_virtual_destructor_v<T>; ///< checks if `T` has a virtual destructor.
template<typename T> concept is_standard_layout = std::is_standard_layout_v<T>;                        ///< checks if `T` is standard layout.
template<typename T> concept trivial = std::is_trivially_copyable_v<T>;                                ///< checks if `T` is trivially copyable.

template<typename T> concept is_void = same_as<remove_cv<T>, void>;                               ///< checks if `T` is `void`.
template<typename T> concept is_bool = same_as<remove_cv<T>, bool>;                               ///< checks if `T` is `bool`.
template<typename T> concept is_none = same_as<remove_cv<T>, none>;                               ///< checks if `T` is `none`.
template<typename T> concept character = included_in<remove_cv<T>, cat1, cat2, uct1, uct2, uct4>; ///< checks if `T` is a character type.
template<typename T> concept integral = std::integral<remove_cv<T>>;                              ///< checks if `T` is an integer type.
template<typename T> concept arithmetic = integral<T> || std::floating_point<T>;                  ///< checks if `T` is a integer or floating point type.

namespace _{
template<typename T> struct _add_cv { using c = const T; using v = volatile T; using cv = const volatile T; };
template<typename T> struct _add_cv<T&> { using c = const T&; using v = volatile T&; using cv = const volatile T&; };
template<typename T> struct _add_cv<T&&> { using c = const T&&; using v = volatile T&&; using cv = const volatile T&&; };
template<typename T> struct _add_pointer : t_type<T> {};
template<typename T> requires valid<T*> struct _add_pointer<T> : t_type<T*> {};
template<typename T> requires valid<T*> struct _add_pointer<T&> : t_type<T*&> {};
template<typename T> requires valid<T*> struct _add_pointer<T&&> : t_type<T*&&> {};
template<typename T, nat N> struct _add_extent : t_type<T> {};
template<typename T, nat N> requires valid<T[N]> struct _add_extent<T, N> : t_type<T[N]> {};
template<typename T, nat N> requires valid<T[N]> struct _add_extent<T&, N> : t_type<T(&)[N]> {};
template<typename T, nat N> requires valid<T[N]> struct _add_extent<T&&, N> : t_type<T(&&)[N]> {};
template<typename T> requires valid<T[]> struct _add_extent<T, 0> : t_type<T[]> {};
template<typename T> requires valid<T[]> struct _add_extent<T&, 0> : t_type<T(&)[]> {};
template<typename T> requires valid<T[]> struct _add_extent<T&&, 0> : t_type<T(&&)[]> {};
}
template<typename T> using add_const = typename _::_add_cv<T>::c;                   ///< adds `const` qualifier to `T`.
template<typename T> using add_volatile = typename _::_add_cv<T>::v;                ///< adds `volatile` qualifier to `T`.
template<typename T> using add_cv = add_const<add_volatile<T>>;                     ///< adds `const` and `volatile` qualifier to `T`.
template<typename T> using add_lvref = std::add_lvalue_reference_t<T>;              ///< adds lvalue reference to `T`.
template<typename T> using add_rvref = std::add_rvalue_reference_t<remove_ref<T>>;  ///< adds rvalue reference to `T`.
template<typename T> using add_fwref = std::add_rvalue_reference_t<T>;              ///< adds forward reference to `T`.
template<typename T> using add_pointer = typename _::_add_pointer<T>::type;         ///< adds pointer to `T`.
template<typename T, nat N> using add_extent = typename _::_add_extent<T, N>::type; ///< adds extent to `T`.

inline consteval auto cev(auto a) noexcept { return a; }                               ///< forces constant evaluation.
template<typename T> inline constexpr auto declval = []() noexcept -> add_fwref<T> {}; ///< returns a reference to `T`.

/// @brief checks if `T` is destructible.
template<typename T> concept destructible = std::is_destructible_v<T>;
/// @brief checks if `T` is destructible without throwing exceptions.
template<typename T> concept nt_destructible = destructible<T> && std::destructible<T>;
/// @brief checks if `T` is assignable from `A`.
template<typename T, typename A> concept assignable = std::is_assignable_v<T, A>;
/// @brief checks if `T` is assignable from `A` without throwing exceptions.
template<typename T, typename A> concept nt_assignable =
  requires { requires assignable<T, A>; requires std::is_nothrow_assignable_v<T, A>; };
/// @brief checks if `T` is constructible from `As...`.
template<typename T, typename... As> concept constructible = requires { T{declval<As>()...}; };
/// @brief checks if `T` is constructible from `As...` without throwing exceptions.
template<typename T, typename... As> concept nt_constructible =
  requires { requires constructible<T, As...>; { T{declval<As>()...} } noexcept; };

/// @brief returns address of `Ref`.
inline constexpr auto addressof = []<is_lvref T>(T&& Ref) noexcept { return __builtin_addressof(Ref); };
/// @brief returns `Ref` as `const`.
inline constexpr auto asconst = []<typename T>(T&& Ref) noexcept -> add_const<T&&> { return Ref; };
/// @brief returns `Ref` as rvalue reference.
inline constexpr auto mv = []<typename T>(T&& Ref) noexcept -> decltype(auto) { return static_cast<add_rvref<T>>(Ref); };
/// @brief returns `Ref` as forward reference.
template<typename T> inline constexpr auto fwd = [](auto&& Ref) noexcept -> decltype(auto) { return static_cast<T&&>(Ref); };
/// @brief assigns `B` to `A` and returns old value of `A`.
inline constexpr auto exchange = []<typename T, typename U = T>(T& A, U&& B) noexcept(nt_constructible<T, T>&& nt_assignable<T&, U>)
  requires constructible<T, T> && assignable<T&, U> { auto a = mv(A); A = fwd<U>(B); return a; };
/// @brief returns `std::bit_cast<T>(Ref)`.
template<trivial T> inline constexpr auto bitcast = [](const trivial auto& Ref) noexcept
  requires (sizeof(T) == sizeof(Ref)) { return __builtin_bit_cast(T, Ref); };

namespace _ {
template<typename T, T I, typename... Ts> struct _type_switch : _type_switch<nat, I, Ts...> {};
template<bool B, typename Tt, typename Tf> struct _type_switch<bool, B, Tt, Tf> : std::conditional<B, Tt, Tf> {};
template<nat I, typename T, typename... Ts> struct _type_switch<nat, I, T, Ts...> : _type_switch<nat, I - 1, Ts...> {};
template<typename T, typename... Ts> struct _type_switch<nat, 0, T, Ts...> : t_type<T> {};
}
/// @brief returns `I`-th type from `Ts...`.
template<convertible_to<nat> auto I, typename... Ts>
requires ((is_bool<decltype(I)> && sizeof...(Ts) == 2) ||
          (!is_bool<decltype(I)> && static_cast<nat>(I) < sizeof...(Ts)))
using type_switch = typename _::_type_switch<decltype(I), I, Ts...>::type;
/// @brief returns `I`-th value from `Vs...`.
template<convertible_to<nat> auto I, auto... Vs>
requires ((is_bool<decltype(I)> && sizeof...(Vs) == 2) ||
          (!is_bool<decltype(I)> && static_cast<nat>(I) < sizeof...(Vs)))
inline constexpr auto value_switch = type_switch<I, constant<Vs>...>::value;
/// @brief returns `I`-th parameter from `Arg, Args...`.
template<convertible_to<nat> auto I>
inline constexpr auto parameter_switch = []<typename A, typename... As>(A&& Arg, As&&... Args) noexcept -> decltype(auto)
  requires ((is_bool<decltype(I)> && sizeof...(As) == 1) || (!is_bool<decltype(I)> && static_cast<nat>(I) <= sizeof...(As))) {
  if constexpr (is_bool<decltype(I)>) return parameter_switch<nat(!I)>(fwd<A>(Arg), fwd<As>(Args)...);
  else if constexpr (same_as<decltype(I), nat>) {
    if constexpr (I == 0) return fwd<A>(Arg); else return parameter_switch<I - 1>(fwd<As>(Args)...); }
  else return parameter_switch<nat(I)>(fwd<A>(Arg), fwd<As>(Args)...); };

/// @brief returns the argument as it.
struct pass { template<typename T> constexpr T&& operator()(T&& a) const noexcept { return static_cast<T&&>(a); } };

/// @brief overloads functions.
template<typename... Fs> struct overload : public Fs... { using Fs::operator()...; };

/// @brief counts the number of `true` in `Bs`.
template<bool... Bs> inline constexpr nat counts = (nat(0) + ... + Bs);

/// @brief counts the number of `false` before the first `true` in `Bs`.
template<bool... Bs> inline constexpr nat inspects = 0;
template<bool B, bool... Bs> inline constexpr nat inspects<B, Bs...> = B ? 0 : 1 + inspects<Bs...>;

/// @brief adds `const` qualifier to `T` if `Src` has.
template<typename T, typename Src> using copy_const = type_switch<is_const<Src>, add_const<T>, T>;
/// @brief adds `volatile` qualifier to `T` if `Src` has.
template<typename T, typename Src> using copy_volatile = type_switch<is_volatile<Src>, add_volatile<T>, T>;
/// @brief adds `const` and/or `volatile` qualifier to `T` if `Src` has.
template<typename T, typename Src> using copy_cv = copy_const<copy_volatile<T, Src>, Src>;

