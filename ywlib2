/// @brief allocates memory for momentary memos
template<typename T> inline constexpr caster memo{
  []() noexcept -> remove_extent<T>* requires is_bounded_array<T> {
    constexpr nat l = sizeof(T), m = l % _::_memo_align, n = m ? l + _::_memo_align - m : l;
    if (const nat o = _::_memo_offset + n; o <= _::_memo_size) {
      return reinterpret_cast<remove_extent<T>*>(exchange(_::_memo_offset, 0));
    } else return _::_memo_offset = n, reinterpret_cast<remove_extent<T>*>(_::_memo);
  },
  [](const nat Extent) noexcept -> T* {
  const nat l = sizeof(T) * Extent, m = l % _::_memo_align, n = m ? l + _::_memo_align - m : l;
  if (const nat o = _::_memo_offset + n; o <= _::_memo_size) {
    return reinterpret_cast<T*>(_::_memo + exchange(_::_memo_offset, 0));
  } else return _::_memo_offset = n, reinterpret_cast<T*>(_::_memo); }};

/// @brief insures this is null-terminated
template<character Ct> struct null_terminated {
  const Ct* const p;
  constexpr null_terminated(const Ct* const P) noexcept : p(P) {}
  constexpr null_terminated(const std::basic_string<Ct>& S) noexcept : p(S.c_str()) {}
  constexpr null_terminated(const std::basic_string_view<Ct>& S) noexcept
    : p([](auto& s, Ct* const o) noexcept { return *std::char_traits<Ct>::copy(o, s.data(), s.size()) = 0, o; }(S, memo<Ct>(S.size() + 1))) {}
  constexpr operator const Ct*() const noexcept { return p; }
};

