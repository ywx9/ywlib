namespace yw {

template<typename T> class staging_buffer;

/// @brief base class for Direct3D 11 resources
template<typename T> class buffer {
protected:
  comptr<ID3D11Buffer> d3d_buffer;
  buffer(const buffer&) = delete;
  buffer& operator=(const buffer&) = delete;
  buffer(auto Count) noexcept : count(unsigned(Count)) {}
public:
  using value_type = T;
  const unsigned count;
  buffer() noexcept : count() {}
  buffer(buffer&& b) noexcept : d3d_buffer(std::move(b.d3d_buffer)), count(b.count) {}
  explicit operator bool() const noexcept { return bool(d3d_buffer); }
  operator ID3D11Buffer*() const noexcept { return d3d_buffer; }

  /// @brief copies from another buffer
  void from(const buffer& b) {
    tiff(main::d3d_device, "main::d3d_device is not initialized");
    tiff(d3d_buffer, "The buffer is not initialized");
    tiff(b.d3d_buffer, "The source buffer is not initialized");
    tiff(count == b.count, "The buffer sizes are different");
    main::d3d_context->CopyResource(d3d_buffer, b.d3d_buffer);
  }

  /// @brief copies to cpu memory
  std::vector<T> to_cpu() const;
  std::vector<T> to_cpu(staging_buffer<T>&) const;
};

template<typename T> class staging_buffer : public buffer<T> {
public:
  staging_buffer() noexcept = default;
  explicit staging_buffer(auto Count) : buffer<T>(Count) {
    tiff(main::d3d_device, "main::d3d_device is not initialized");
    D3D11_BUFFER_DESC desc{sizeof(T) * buffer<T>::count, D3D11_USAGE_STAGING, 0, D3D11_CPU_ACCESS_READ};
    tiff(main::d3d_device->CreateBuffer(&desc, nullptr, buffer<T>::d3d_buffer.init()));
  }
  explicit staging_buffer(const buffer<T>& b) : staging_buffer(b.count) { buffer<T>::from(b); }
  std::vector<T> to_cpu() const {
    tiff(buffer<T>::d3d_buffer, "The buffer is not initialized");
    std::vector<T> data(buffer<T>::count);
    D3D11_MAPPED_SUBRESOURCE map{};
    tiff(main::d3d_context->Map(buffer<T>::d3d_buffer, 0, D3D11_MAP_READ, 0, &map));
    std::memcpy(data.data(), map.pData, sizeof(T) * buffer<T>::count);
    main::d3d_context->Unmap(buffer<T>::d3d_buffer, 0);
    return data;
  }
};
template<typename T> staging_buffer(const buffer<T>&) -> staging_buffer<T>;

template<typename T> std::vector<T> buffer<T>::to_cpu() const {
  tiff(d3d_buffer, "The buffer is not initialized");
  staging_buffer<T> staging(*this);
  return staging.to_cpu();
}
template<typename T> std::vector<T> buffer<T>::to_cpu(staging_buffer<T>& staging) const {
  tiff(d3d_buffer, "The buffer is not initialized");
  staging.from(*this);
  return staging.to_cpu();
}

