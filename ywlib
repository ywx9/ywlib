        return _mm_insert_ps(t_xvpermute<xa, ya, za, wa>::call(A), B, int((select_value<i, xa, ya, za, wa> - 4) << 6 | i << 4));
      } else if constexpr ((xb < 4) + (yb < 4) + (zb < 4) + (wb < 4) == 1) {
        constexpr nat i = inspects<(xb < 4), (yb < 4), (zb < 4), (wb < 4)>;
        return _mm_insert_ps(t_xvpermute<xb - 4, yb - 4, zb - 4, wb - 4>::call(B), A, int(select_value<i, xb, yb, zb, wb> << 6 | i << 4));
