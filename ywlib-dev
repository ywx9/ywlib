/// @file ywlib-dev
/// @brief header for testing.

#pragma once
#include "ywlib"

namespace yw::dev {

/// @brief 3D model class.
struct model {
  /// @brief vertex buffer with position and normal.
  /// @note normal vector must be normalized.
  /// @note w-component of position must be `1`.
  /// @note w-component of normal must be `0`.
  const structured_buffer<list<vector, vector>> vertices{};
  /// @brief edge buffer with two vertex indices.
  /// @note order of vetices is important for face buffer.
  const structured_buffer<list<unsigned, unsigned>> edges{};
  /// @brief face buffer with three edge indices.
  /// @note if the index is negative, the edge is reversed.
  /// @note order of edge must be `{AB, BC, CA}`.
  const structured_buffer<list<int, int, int>> faces{};

  /// @brief world matrix.
  matrix world{xv_x, xv_y, xv_z, xv_w};

  /// @brief default shader code for default rendering.
  static constexpr auto default_shader = R"(
#pragma pack_matrix(row_major) // mathematical
struct Vertex { float4 position, normal; };
StructuredBuffer<Vertex> vertices : register(t0);
struct Edge { uint2 vertices; };
StructuredBuffer<Edge> edges : register(t1);
struct Face { int3 edges; };
StructuredBuffer<Face> faces : register(t2);
cbuffer World : register(b0) { matrix world; };
cbuffer Camera : register(b1) { matrix view, view_projection; };
cbuffer Color : register(b2) { float4 vertex_color; };
  )";
};

}
