struct source {
  const char* const file;
  const int line, column;
  source(const char* const) = delete;
  constexpr source(const char* const File = __builtin_FILE(), const int Line = __builtin_LINE(), const int Column = __builtin_COLUMN()) noexcept : file(mv(File)), line(Line), column(Column) {}
  str1 to_string() const { return std::format("{}({},{})", file, line, column); }
  template<character Ct> string<Ct> to_string() const {
    if constexpr (same_as<remove_cv<Ct>, cat1>) return std::format("{}({},{})", std::filesystem::path(file).string<Ct>(), line, column);
    else if constexpr (same_as<remove_cv<Ct>, cat2>) return std::format(L"{}({},{})", std::filesystem::path(file).string<Ct>(), line, column);
    else if constexpr (same_as<remove_cv<Ct>, uct1>) return std::format(u8"{}({},{})", std::filesystem::path(file).string<Ct>(), line, column);
    else if constexpr (same_as<remove_cv<Ct>, uct2>) return std::format(u"{}({},{})", std::filesystem::path(file).string<Ct>(), line, column);
    else if constexpr (same_as<remove_cv<Ct>, uct4>) return std::format(U"{}({},{})", std::filesystem::path(file).string<Ct>(), line, column);
  }
  template<typename Ct, typename Tr> friend std::basic_ostream<char, Tr>& operator<<(std::basic_ostream<Ct, Tr>& os, const source& s) { return os << s.to_string<Ct>(); }
};

