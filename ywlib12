namespace yw::main::system {
/// @brief manages the main window.
struct Window {
  inline static bool success{};        // true if the window is created successfully.
  inline static HINSTANCE hinstance{}; // instance of the window.
  inline static HWND hwnd{};           // handle of the window.
  inline static bool hover{};          // true if the mouse is hovering over the window.
  inline static RECT mouse{};          // position of the mouse.
  inline static key::key keys[256];    // array of keys on the keyboard.
  static LRESULT CALLBACK wndproc(HWND hw, UINT msg, WPARAM wp, LPARAM lp);
  Window() {
    static constexpr auto title = L"ywlib12";
    static constexpr auto width = 640;
    static constexpr auto height = 480;
    static constexpr auto style = WS_OVERLAPPED | WS_SYSMENU | WS_CLIPCHILDREN;
    hinstance = GetModuleHandleW(nullptr);
    if (!hinstance) return;
    WNDCLASSEXW wc{sizeof(WNDCLASSEXW), CS_OWNDC, wndproc, 0, 0, hinstance};
    wc.hCursor = ::LoadCursorW(nullptr, IDC_ARROW), wc.lpszClassName = title;
    if (!::RegisterClassExW(&wc)) return;
    RECT rc{0, 0, width, height};
    ::AdjustWindowRect(&rc, style, false);
    hwnd = ::CreateWindowExW(WS_EX_ACCEPTFILES, title, title, style, CW_USEDEFAULT, CW_USEDEFAULT,
                             rc.right - rc.left, rc.bottom - rc.top, nullptr, nullptr, hinstance, nullptr);
    if (!hwnd) return;
    ::ShowWindow(hwnd, SW_SHOW);
    ::SetForegroundWindow(hwnd);
    ::SetFocus(hwnd);
    success = true;
  }
};
}

