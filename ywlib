template<typename T, typename Setter = none> class status {
protected:
  T _status;
  bool _changed;
public:
  status() noexcept : _status{}, _changed{false} {}
  status(const T& Init) noexcept : _status{Init}, _changed{false} {}
  status(T&& Init) noexcept : _status{mv(Init)}, _changed{false} {}
  explicit operator bool() const noexcept { return _changed; }
  operator T() const noexcept { return _changed = false, _status; }
  bool changed() const noexcept { return _changed; }
  void set(const T& New) noexcept(nt_assignable<T&, const T&>) { _changed = true, _status = New, Setter{}(New); }
  void set(T&& New) noexcept(nt_assignable<T&, T>) { _changed = true, _status = mv(New), Setter{}(New); }
  T get() noexcept { return _changed = false, _status; }
};

template<typename Setter> class status<bool, Setter> {
protected:
  bool _status;
  bool _changed;
public:
  status() noexcept : _status{}, _changed{false} {}
  status(bool Init) noexcept : _status{Init}, _changed{false} {}
  operator bool() noexcept { return _changed = false, _status; }
  bool changed() const noexcept { return _changed; }
  void set(bool New) noexcept { _changed = true, _status = New, Setter{}(New); }
  bool get() noexcept { return _changed = false, _status; }
};

