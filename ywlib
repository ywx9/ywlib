      if (*i < 0x10000) wcs[size++] = cat2(*i);
      else if (*i < 0x110000) {
        wcs[size++] = cat2(0xD800 + (*i - 0x10000) / 0x400);
        wcs[size++] = cat2(0xDC00 + (*i - 0x10000) % 0x400);
      } else break; }
    wcs.resize(size); return wcs;
  }
  /// Convert a multi-byte-string to wide-char-string.
  string<cat2> operator()(const string_view<cat1>& mbs) const {
    if (mbs.empty()) return {};
    if (auto size = ::MultiByteToWideChar(CP_ACP, 0, mbs.data(), -1, nullptr, 0); size) {
      string<cat2> wcs(size - 1, L'\0');
      ::MultiByteToWideChar(CP_ACP, 0, mbs.data(), -1, reinterpret_cast<cat2*>(wcs.data()), size);
      return wcs;
    } else return {};
  }
  /// Convert a wide-char-string to wide-char-string.
  constexpr string<cat2> operator()(const string_view<cat2>& wcs) const {
    return string<cat2>(wcs);
  } };
/// Convert a string to wide-char-string.
